    fetch("/reportes/guardar-cierre/", {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRFToken': 'pqstREp2H3T3NVn0MNtotzcI75sn1Y0teE2b84JpJmsd2uckGZiww5OBvPkw9tnA' },
      body: JSON.stringify({ fecha, notas }),
    })
      .then(r => r.json())
      .then(data => {
        if (data.ok) {
          feedback.textContent = `Cierre ${data.accion} correctamente.`;
          feedback.className = 'cierre-feedback text-success';
          setTimeout(() => location.reload(), 1500);
