    background: #fff;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .producto-card:hover {
    border-color: #2d6a4f;
    box-shadow: 0 6px 18px rgba(0,0,0,0.13);
  }

  .producto-card:active {
    transform: scale(0.97);
  }

  /* Zona de imagen */
  .producto-card .card-img-wrap {
    height: 90px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f8f9fa;
    border-radius: 10px 10px 0 0;
    overflow: hidden;
    flex-shrink: 0;
  }

  .producto-card img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 6px;
  }

  .producto-card .placeholder-icon {
    font-size: 2rem;
    color: #dee2e6;
  }

  .producto-card .card-body {
    padding: 0.45rem 0.6rem 0.55rem;
    display: flex;
    flex-direction: column;
    gap: 1px;
    flex: 1;
  }

  .producto-card .nombre {
    font-size: 0.8rem;
    font-weight: 600;
    line-height: 1.2;
    color: #212529;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    line-clamp: 2;
    overflow: hidden;
  }

  .producto-card .precio-bs {
    font-size: 0.95rem;
    font-weight: 800;
    color: #2d6a4f;
    margin-top: 3px;
  }

  .producto-card .precio-usd {
    font-size: 0.72rem;
    color: #6c757d;
  }

  .producto-card .stock-info {
    display: inline-flex;
