    gap: 1.25rem;
    height: calc(100vh - 90px); /* viewport menos navbar */
  }

  /* ── Columna izquierda: búsqueda + productos ──────────────── */
  .col-productos {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
    overflow-x: clip; /* evita que los chips desborden hacia el carrito */
  }

  .buscador-wrap {
    position: sticky;
    top: 0;
    z-index: 10;
    background-color: #f4f6f9;
    padding-bottom: 0.75rem;
  }

  .buscador-wrap .input-group {
    box-shadow: 0 2px 8px rgba(0,0,0,0.10);
    border-radius: 10px;
    overflow: hidden;
  }

  #buscador {
    font-size: 1.2rem;
    padding: 0.65rem 1rem;
    border: none;
    outline: none;
  }

  #buscador:focus {
    box-shadow: none;
  }

  .btn-limpiar {
    background-color: #e9ecef;
    border: none;
    padding: 0 1rem;
    font-size: 1.1rem;
    color: #6c757d;
  }

