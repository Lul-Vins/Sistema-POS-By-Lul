    border-radius: 4px;
    padding: 1px 5px;
    transition: background .12s;
  }
  .qty-num-unit:hover { background: #e9ecef; }

  .carrito-item .item-info {
    flex: 1;
    min-width: 0; /* permite que el texto se comprima en el flex */
  }

  .carrito-item .item-nombre {
    font-size: 0.92rem;
    font-weight: 600;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .carrito-item .item-precio {
    font-size: 0.82rem;
    color: #6c757d;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .carrito-item .item-subtotal {
    font-size: 0.95rem;
    font-weight: 700;
    color: #2d6a4f;
    white-space: nowrap;
  }

  /* Control de cantidad */
  .qty-control {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .qty-control button {
    width: 26px;
    height: 26px;
    border-radius: 6px;
    border: 1px solid #dee2e6;
    background: #f8f9fa;
    font-size: 1rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #495057;
    transition: background 0.1s;
  }

  .qty-control button:hover {
    background: #e9ecef;
  }

  .qty-control .qty-num {
    min-width: 28px;
    text-align: center;
    font-size: 0.95rem;
    font-weight: 700;
  }

  /* ── Footer del carrito: totales + cobrar ─────────────────── */
  .carrito-footer {
    flex-shrink: 0;
    border-top: 2px solid #f0f0f0;
    padding: 1rem 1.25rem;
  }

  .total-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.3rem;
  }

  .total-row .label {
    font-size: 0.9rem;
    color: #6c757d;
  }

  .total-row .valor-usd {
    font-size: 0.9rem;
    font-weight: 400;
    color: #6c757d;
  }

  .total-row .valor-bs {
    font-size: 1.5rem;
    font-weight: 800;
    color: #1a1a2e;
  }

  .btn-cobrar {
    width: 100%;
    padding: 0.75rem;
    font-size: 1.15rem;
    font-weight: 700;
    background-color: #2d6a4f;
    color: #fff;
    border: none;
    border-radius: 10px;
    margin-top: 0.75rem;
    transition: background-color 0.15s;
  }

  .btn-cobrar:hover:not(:disabled) {
    background-color: #1b4332;
  }

  .btn-cobrar:disabled {
    background-color: #ced4da;
    cursor: not-allowed;
  }

  .btn-vaciar {
    width: 100%;
    font-size: 0.85rem;
    color: #dc3545;
    background: none;
    border: none;
    margin-top: 0.4rem;
    cursor: pointer;
  }

  .btn-vaciar:hover {
    text-decoration: underline;
  }
</style>

