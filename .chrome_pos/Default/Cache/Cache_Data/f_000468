<script>
  let TASA              = parseFloat("600,00") || 0;
  const IMPRIMIR_TICKET = false;
  const TASA_VENCIDA    = false;
  const URL_TICKET      = "/ticket/0/".replace('/0/', '/');
  const URL_BUSCAR      = "/buscar/";
  let carrito        = {};
  let timerBusqueda  = null;
  let catSeleccionada = null;

  // ── Elementos del DOM ──────────────────────────────────────
  const buscador            = document.getElementById('buscador');
  const btnLimpiar          = document.getElementById('btn-limpiar');
  const grid                = document.getElementById('productos-grid');
  const estadoInicial       = document.getElementById('estado-inicial');
  const estadoCargando      = document.getElementById('estado-cargando');
  const estadoSinResultados = document.getElementById('estado-sin-resultados');
  const terminoSpan         = document.getElementById('termino-busqueda');

  // ── Búsqueda AJAX con debounce ─────────────────────────────
  buscador.addEventListener('input', function () {
    const q = this.value.trim();
    clearTimeout(timerBusqueda);

    if (q.length < 2 && !catSeleccionada) {
      mostrarEstado('inicial');
      grid.innerHTML = '';
      return;
    }

    mostrarEstado('cargando');
    timerBusqueda = setTimeout(() => buscar(q, false, catSeleccionada), 300);
  });

  // Enter: búsqueda inmediata (flujo lector de barras)
  buscador.addEventListener('keydown', function (e) {
    if (e.key !== 'Enter') return;
    const q = this.value.trim();
    if (q.length < 2 && !catSeleccionada) return;
    clearTimeout(timerBusqueda);
    buscar(q, q.length >= 2, catSeleccionada);
  });

  btnLimpiar.addEventListener('click', () => {
    buscador.value = '';
    if (catSeleccionada) {
      mostrarEstado('cargando');
      buscar('', false, catSeleccionada);
    } else {
      buscador.dispatchEvent(new Event('input'));
    }
    buscador.focus();
  });

  // ── Navegación de chips ────────────────────────────────────
  function actualizarBotonesChips() {
    const wrap = document.getElementById('cat-chips-wrap');
    const prev = document.getElementById('chips-prev');
    const next = document.getElementById('chips-next');
    if (!wrap || !prev || !next) return;
    prev.style.display = wrap.scrollLeft > 1 ? '' : 'none';
    next.style.display = wrap.scrollLeft < wrap.scrollWidth - wrap.clientWidth - 1 ? '' : 'none';
  }
  function scrollChips(dir) {
    const wrap = document.getElementById('cat-chips-wrap');
    if (!wrap) return;
    wrap.scrollBy({ left: dir * 180, behavior: 'smooth' });
    setTimeout(actualizarBotonesChips, 320);
  }
  (function () {
    const wrap = document.getElementById('cat-chips-wrap');
    if (!wrap) return;
    wrap.addEventListener('scroll', actualizarBotonesChips);
    actualizarBotonesChips();
  })();

  // ── Filtro por categoría ───────────────────────────────────
  function seleccionarCategoria(catId, btnEl) {
    document.querySelectorAll('.cat-chip').forEach(b => b.classList.remove('activa'));
    btnEl.classList.add('activa');
    catSeleccionada = catId || null;

    const q = buscador.value.trim();
    if (catSeleccionada) {
      mostrarEstado('cargando');
      buscar(q.length >= 2 ? q : '', false, catSeleccionada);
    } else {
      if (q.length >= 2) {
        mostrarEstado('cargando');
        buscar(q, false, null);
      } else {
        mostrarEstado('inicial');
        grid.innerHTML = '';
      }
    }
    buscador.focus();
  }

  function buscar(q, agregarDirecto = false, catId = null) {
    const params = new URLSearchParams();
    if (q)     params.set('q',   q);
    if (catId) params.set('cat', catId);

    fetch(`${URL_BUSCAR}?${params}`)
      .then(r => r.json())
      .then(data => {
        const productos = data.productos;
        grid.innerHTML = '';

        if (productos.length === 0) {
          terminoSpan.textContent = q || 'esta categoría';
          mostrarEstado('sin-resultados');
          return;
        }

        mostrarEstado('grid');
        productos.forEach(p => grid.appendChild(crearTarjeta(p)));

        // Lector de barras: si hay exactamente 1 resultado, agrégalo y limpia
        if (agregarDirecto && productos.length === 1) {
          const p = productos[0];
          if (p.vendido_por_peso) {
            abrirDialogoKg(p.id, p.nombre, p.precio_usd, p.stock_actual);
          } else {
            agregarAlCarrito(p.id, p.nombre, p.precio_usd, false, 1, p.stock_actual);
          }
          buscador.value = '';
          if (catSeleccionada) {
            buscar('', false, catSeleccionada);
          } else {
            buscador.dispatchEvent(new Event('input'));
          }
        }
      })
      .catch(() => mostrarEstado('inicial'));
  }

  function crearTarjeta(p) {
    const col = document.createElement('div');
    col.className = 'col';

    const imgHtml = p.imagen
      ? `<img src="${p.imagen}" alt="${p.nombre}">`
      : `<i class="bi bi-box-seam placeholder-icon"></i>`;

    const bsHtml = p.precio_bs
      ? `Bs. ${p.precio_bs.toFixed(2)}`
      : `Bs. —`;

    const stockIcono = p.stock_bajo ? 'bi-exclamation-triangle-fill' : 'bi-box-seam';
    const stockClase = p.stock_bajo ? 'bajo' : '';
    const unidad    = p.vendido_por_peso ? 'kg' : 'ud';
    const stockText = p.vendido_por_peso
      ? `${parseFloat(p.stock_actual.toFixed(3)).toString().replace('.', ',')} kg`
      : p.stock_actual;
    const stockHtml = `<div class="stock-info ${stockClase}">
      <i class="bi ${stockIcono}"></i> Stock: ${stockText}
    </div>`;
    const precioLabel = p.vendido_por_peso
      ? `Bs. ${p.precio_bs ? p.precio_bs.toFixed(2) : '—'}/kg`
      : bsHtml;
    const precioUsdLabel = p.vendido_por_peso
      ? `$ ${p.precio_usd.toFixed(2)}/kg`
      : `$ ${p.precio_usd.toFixed(2)}`;

    col.innerHTML = `
      <div class="card producto-card"
           data-id="${p.id}"
           data-nombre-producto="${p.nombre}"
           data-precio="${p.precio_usd}"
           data-stock="${p.stock_actual}"
           data-por-peso="${p.vendido_por_peso ? 'true' : 'false'}">
        <div class="card-img-wrap">${imgHtml}</div>
        <div class="card-body">
          <div class="nombre">${p.nombre}</div>
          <div class="precio-bs">${precioLabel}</div>
          <div class="precio-usd">${precioUsdLabel}</div>
          ${stockHtml}
        </div>
      </div>`;
    return col;
  }

  function mostrarEstado(estado) {
    estadoInicial.style.display       = estado === 'inicial'       ? 'flex' : 'none';
    estadoCargando.style.display      = estado === 'cargando'      ? 'flex' : 'none';
    estadoSinResultados.style.display = estado === 'sin-resultados'? 'flex' : 'none';
    grid.style.display                = estado === 'grid'          ? ''     : 'none';
  }

  // ── Click en tarjeta (delegado en el grid) ─────────────────
  grid.addEventListener('click', function (e) {
    const card = e.target.closest('.producto-card');
    if (!card) return;
    const stock = parseFloat(card.dataset.stock);
    if (card.dataset.porPeso === 'true') {
      abrirDialogoKg(card.dataset.id, card.dataset.nombreProducto, parseFloat(card.dataset.precio), stock);
    } else {
      agregarAlCarrito(card.dataset.id, card.dataset.nombreProducto, parseFloat(card.dataset.precio), false, 1, stock);
    }
  });

  // ── Diálogo de cantidad en kg ───────────────────────────────
  function abrirDialogoKg(id, nombre, precioUsd, stock = null) {
    document.getElementById('kg-dialog-nombre').textContent = nombre;
    document.getElementById('kg-dialog-precio').textContent =
      `$ ${precioUsd.toFixed(2)}/kg`;
    document.getElementById('kg-input').value = carrito[id]
      ? carrito[id].cantidad.toFixed(3)
      : '';

    _kgPendiente = { id, nombre, precioUsd, stock: stock ?? carrito[id]?.stock ?? null };
    new bootstrap.Modal(document.getElementById('modalKg')).show();
    setTimeout(() => document.getElementById('kg-input').focus(), 300);
  }

  let _kgPendiente = null;

  document.getElementById('btn-kg-ok').addEventListener('click', confirmarKg);
  document.getElementById('kg-input').addEventListener('keydown', e => {
    if (['e','E','+','-'].includes(e.key)) { e.preventDefault(); return; }
    if (e.key === 'Enter') confirmarKg();
  });
  document.getElementById('kg-input').addEventListener('paste', e => {
    e.preventDefault();
    const txt = (e.clipboardData || window.clipboardData).getData('text')
      .replace(/[^\d.]/g, '').replace(',', '.');
    e.target.value = txt;
  });

  function confirmarKg() {
    const val = parseFloat(document.getElementById('kg-input').value);
    if (!val || isNaN(val) || val <= 0) {
      document.getElementById('kg-feedback').textContent = 'Ingresa una cantidad mayor a 0.';
      return;
    }
    if (val > 9999) {
      document.getElementById('kg-feedback').textContent = 'La cantidad no puede superar 9.999 kg.';
      return;
    }
    const { id, nombre, precioUsd, stock } = _kgPendiente;
    bootstrap.Modal.getInstance(document.getElementById('modalKg')).hide();
    agregarAlCarrito(id, nombre, precioUsd, true, parseFloat(val.toFixed(3)), stock);
  }

  // ── Lógica del carrito ─────────────────────────────────────
  function agregarAlCarrito(id, nombre, precioUsd, porPeso, cantidad, stock = null) {
    if (carrito[id] && !porPeso) {
      carrito[id].cantidad += cantidad;
    } else {
      carrito[id] = { nombre, precio_usd: precioUsd, cantidad, por_peso: porPeso, stock };
    }
    renderCarrito();
    buscador.focus();
  }

  function cambiarCantidad(id, delta) {
    if (!carrito[id]) return;
    const paso = carrito[id].por_peso ? 0.1 : 1;
    carrito[id].cantidad = parseFloat((carrito[id].cantidad + delta * paso).toFixed(3));
    if (carrito[id].cantidad <= 0) delete carrito[id];
    renderCarrito();
  }

  function editarCantidadKg(id) {
    if (!carrito[id]) return;
    abrirDialogoKg(id, carrito[id].nombre, carrito[id].precio_usd, carrito[id].stock);
  }

  function editarCantidadUnidad(id) {
    if (!carrito[id]) return;
    const contenedor = document.getElementById('carrito-items');
    const el   = contenedor.querySelector(`.carrito-item[data-id="${id}"]`);
    if (!el) return;
    const span = el.querySelector('.qty-num-unit');
    if (!span) return;

    const inp = document.createElement('input');
    inp.type  = 'number';
    inp.min   = '1';
    inp.max   = '9999';
    inp.step  = '1';
    inp.value = carrito[id].cantidad;
    inp.style.cssText = 'width:52px;text-align:center;font-size:.9rem;font-weight:700;border:1px solid #2d6a4f;border-radius:4px;padding:1px 4px;';

    function confirmar() {
      const val = parseInt(inp.value);
      if (!isNaN(val) && val >= 1 && val <= 9999) carrito[id].cantidad = val;
      renderCarrito();
    }

    inp.addEventListener('keydown', e => {
      if (['e','E','+','-','.'].includes(e.key)) { e.preventDefault(); return; }
      if (e.key === 'Enter')  { inp.removeEventListener('blur', confirmar); confirmar(); return; }
      if (e.key === 'Escape') { inp.removeEventListener('blur', confirmar); renderCarrito(); return; }
    });
    inp.addEventListener('blur', confirmar);

    span.replaceWith(inp);
    inp.focus();
    inp.select();
  }

  function vaciarCarrito() {
    carrito = {};
    renderCarrito();
  }

  function renderCarrito() {
    const contenedor = document.getElementById('carrito-items');
    const vacio      = document.getElementById('carrito-vacio');
    const countBadge = document.getElementById('carrito-count');
    const btnCobrar  = document.getElementById('btn-cobrar');
    const ids        = Object.keys(carrito);

    contenedor.querySelectorAll('.carrito-item').forEach(el => el.remove());

    if (ids.length === 0) {
      vacio.style.display    = 'flex';
      countBadge.textContent = '0';
      btnCobrar.disabled     = true;
      actualizarTotales(0);
      return;
    }

    vacio.style.display = 'none';

    let totalUsd = 0, totalItems = 0, hayStockError = false;

    ids.forEach(id => {
      const item        = carrito[id];
      const subtotalUsd = item.precio_usd * item.cantidad;
      totalUsd   += subtotalUsd;
      totalItems += item.por_peso ? 1 : item.cantidad;

      const sinStock = item.stock !== null && item.stock !== undefined && item.cantidad > item.stock;
      if (sinStock) hayStockError = true;

      const el = document.createElement('div');
      el.className  = 'carrito-item' + (sinStock ? ' stock-error' : '');
      el.dataset.id = id;
      const precioLabel = item.por_peso
        ? `$ ${item.precio_usd.toFixed(2)}/kg`
        : `$ ${item.precio_usd.toFixed(2)} c/u`;
      const kgDisplay = parseFloat(item.cantidad.toFixed(3)).toString().replace('.', ',');
      const stockDisp = item.stock !== null && item.stock !== undefined
        ? (item.por_peso
            ? parseFloat(item.stock.toFixed(3)).toString().replace('.', ',') + ' kg'
            : item.stock)
        : null;
      const alertaHtml = sinStock
        ? `<div class="stock-alerta"><i class="bi bi-exclamation-triangle-fill me-1"></i>Stock insuficiente — disponible: ${stockDisp}</div>`
        : '';
      const qtyHtml = item.por_peso
        ? `<div class="qty-control">
             <button onclick="cambiarCantidad(${id}, -1)">−</button>
             <span class="qty-num" style="cursor:pointer; background:#f0fdf4; border-radius:6px; padding:1px 5px;"
                   onclick="editarCantidadKg(${id})" title="Clic para editar">
               ${kgDisplay}<small style="font-weight:400; color:#6c757d; font-size:.75em; margin-left:2px;">kg</small>
             </span>
             <button onclick="cambiarCantidad(${id}, +1)">+</button>
           </div>`
        : `<div class="qty-control">
             <button onclick="cambiarCantidad(${id}, -1)">−</button>
             <span class="qty-num qty-num-unit" onclick="editarCantidadUnidad('${id}')" title="Clic para editar">${item.cantidad}</span>
             <button onclick="cambiarCantidad(${id}, +1)">+</button>
           </div>`;
      el.innerHTML  = `
        <div class="item-info">
          <div class="item-nombre" title="${item.nombre}">${truncar(item.nombre)}</div>
          <div class="item-precio">${precioLabel}</div>
          ${alertaHtml}
        </div>
        ${qtyHtml}
        <div class="item-subtotal">$ ${subtotalUsd.toFixed(2)}</div>`;
      contenedor.appendChild(el);
    });

    countBadge.textContent = totalItems;
    btnCobrar.disabled = TASA_VENCIDA || hayStockError;
    actualizarTotales(totalUsd);
  }

  function truncar(texto, max = 40) {
    return texto.length > max ? texto.slice(0, max) + '…' : texto;
  }

  function actualizarTotales(totalUsd) {
    const totalBs = totalUsd * TASA;
    document.getElementById('total-usd').textContent = `$ ${totalUsd.toFixed(2)}`;
    document.getElementById('total-bs').textContent  = `Bs. ${formatBs(totalBs)}`;
  }

  function formatBs(n) {
    return n.toLocaleString('es-VE', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  // ── Modal de cobro ────────────────────────────────────────
  const URL_PROCESAR   = "/procesar/";
  const CSRF_VENTA     = "TC032OjgV40oaKxx0UuLCsPgelotQTbaIQALjeDDXnzypjmRU6jTFYr9C5gCYoyh";
  const modalCobroEl   = document.getElementById('modalCobro');
  const modalCobro     = new bootstrap.Modal(modalCobroEl);
  const inputRecibido  = document.getElementById('monto-recibido');

  function abrirModalCobro() {
    // Sincronizar totales
    const totalUsd = parseFloat(document.getElementById('total-usd').textContent.replace('$','').trim());
    const totalBs  = document.getElementById('total-bs').textContent;
    document.getElementById('cobro-total-usd').textContent = `$ ${totalUsd.toFixed(2)}`;
    document.getElementById('cobro-total-bs').textContent  = totalBs;

    // Limpiar estado anterior
    document.querySelectorAll('input[name="metodo"]').forEach(r => r.checked = false);
    document.getElementById('bloque-vuelto').style.display = 'none';
    document.getElementById('cobro-feedback').textContent  = '';
    document.getElementById('cobro-notas').value           = '';
    inputRecibido.value = '';
    document.getElementById('vuelto-display').textContent  = '$ 0.00';

    modalCobro.show();
  }

  // Mostrar/ocultar bloque de vuelto según método
  document.querySelectorAll('input[name="metodo"]').forEach(radio => {
    radio.addEventListener('change', function () {
      const esEfectivo = ['EFECTIVO_USD', 'EFECTIVO_BS'].includes(this.value);
      const bloqueVuelto = document.getElementById('bloque-vuelto');
      const labelRecibido = document.getElementById('label-monto-recibido');

      bloqueVuelto.style.display = esEfectivo ? 'block' : 'none';

      if (this.value === 'EFECTIVO_BS') {
        labelRecibido.textContent = 'Monto recibido (Bs.)';
        calcularVuelto('BS');
      } else {
        labelRecibido.textContent = 'Monto recibido (USD)';
        calcularVuelto('USD');
      }

      if (esEfectivo) inputRecibido.focus();
    });
  });

  // Calcular vuelto en tiempo real
  inputRecibido.addEventListener('input', function () {
    const metodo = document.querySelector('input[name="metodo"]:checked')?.value;
    calcularVuelto(metodo === 'EFECTIVO_BS' ? 'BS' : 'USD');
  });

  function calcularVuelto(moneda) {
    const totalUsd = parseFloat(document.getElementById('cobro-total-usd').textContent.replace('$','').trim()) || 0;
    const recibido = parseFloat(inputRecibido.value) || 0;
    const el       = document.getElementById('vuelto-display');

    if (moneda === 'BS') {
      const totalBsNum = totalUsd * TASA;
      const vuelto     = recibido - totalBsNum;
      el.textContent   = `Bs. ${formatBs(Math.max(vuelto, 0))}`;
      el.style.color   = vuelto >= 0 ? '#2d6a4f' : '#dc3545';
    } else {
      const vuelto   = recibido - totalUsd;
      el.textContent = `$ ${Math.max(vuelto, 0).toFixed(2)}`;
      el.style.color = vuelto >= 0 ? '#2d6a4f' : '#dc3545';
    }
  }

  // Confirmar venta
  document.getElementById('btn-confirmar-cobro').addEventListener('click', function () {
    const metodo   = document.querySelector('input[name="metodo"]:checked')?.value;
    const feedback = document.getElementById('cobro-feedback');

    if (!metodo) {
      feedback.textContent = 'Selecciona un método de pago.';
      return;
    }

    // Validación de monto recibido para pagos en efectivo
    if (['EFECTIVO_USD', 'EFECTIVO_BS'].includes(metodo)) {
      const totalUsd  = parseFloat(document.getElementById('cobro-total-usd').textContent.replace('$','').trim()) || 0;
      const recibido  = parseFloat(inputRecibido.value) || 0;

      if (!inputRecibido.value.trim()) {
        feedback.textContent = 'Ingresa el monto recibido.';
        inputRecibido.focus();
        return;
      }

      if (isNaN(recibido) || recibido < 0 || recibido > 9_999_999) {
        feedback.textContent = 'Monto recibido inválido.';
        inputRecibido.focus();
        return;
      }

      if (metodo === 'EFECTIVO_USD' && recibido < totalUsd) {
        feedback.textContent = `Monto insuficiente. Faltan $ ${(totalUsd - recibido).toFixed(2)}.`;
        inputRecibido.focus();
        return;
      }

      if (metodo === 'EFECTIVO_BS') {
        const totalBs = totalUsd * TASA;
        if (recibido < totalBs) {
          feedback.textContent = `Monto insuficiente. Faltan Bs. ${formatBs(totalBs - recibido)}.`;
          inputRecibido.focus();
          return;
        }
      }
    }

    const esEfectivo = ['EFECTIVO_USD', 'EFECTIVO_BS'].includes(metodo);
    const recibidoVal = esEfectivo ? (parseFloat(inputRecibido.value) || 0) : null;

    // Calcular vuelto para guardarlo en la BD
    let vueltoVal = null;
    if (esEfectivo) {
      const totalUsdNum = parseFloat(document.getElementById('cobro-total-usd').textContent.replace('$','').trim()) || 0;
      if (metodo === 'EFECTIVO_BS') {
        vueltoVal = recibidoVal - (totalUsdNum * TASA);
      } else {
        vueltoVal = recibidoVal - totalUsdNum;
      }
      vueltoVal = Math.max(parseFloat(vueltoVal.toFixed(2)), 0);
    }

    const payload = {
      carrito:        Object.entries(carrito).map(([id, item]) => ({ id, cantidad: item.cantidad })),
      metodo_pago:    metodo,
      notas:          document.getElementById('cobro-notas').value.trim(),
      monto_recibido: recibidoVal,
      vuelto:         vueltoVal,
    };

    this.disabled    = true;
    this.innerHTML   = '<span class="spinner-border spinner-border-sm me-2"></span>Procesando...';
    feedback.textContent = '';

    fetch(URL_PROCESAR, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRFToken': CSRF_VENTA },
      body:    JSON.stringify(payload),
    })
      .then(r => r.json())
      .then(data => {
        if (data.ok) {
          modalCobro.hide();
          vaciarCarrito();
          mostrarConfirmacion(data);
        } else {
          feedback.textContent = data.error || 'Error al procesar la venta.';
        }
      })
      .catch(() => { feedback.textContent = 'Error de conexión.'; })
      .finally(() => {
        this.disabled  = false;
        this.innerHTML = '<i class="bi bi-check-circle me-2"></i>Confirmar venta';
      });
  });

  const modalPostCobroEl = document.getElementById('modalPostCobro');
  const modalPostCobro   = new bootstrap.Modal(modalPostCobroEl);

  function mostrarConfirmacion(data) {
    document.getElementById('pc-venta-id').textContent  = `Venta #${data.venta_id}`;
    document.getElementById('pc-total-usd').textContent = `$ ${data.total_usd.toFixed(2)}`;
    document.getElementById('pc-total-bs').textContent  = `Bs. ${data.total_bs.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',')}`;

    const btnTicket    = document.getElementById('pc-btn-ticket');
    const ticketStatus = document.getElementById('pc-ticket-status');

    if (IMPRIMIR_TICKET) {
      if (data.ticket_impreso) {
        ticketStatus.style.display = '';
        ticketStatus.style.color   = '#2d6a4f';
        ticketStatus.innerHTML     = '<i class="bi bi-check-circle-fill me-1"></i>Ticket impreso correctamente.';
        btnTicket.style.display    = 'none';
      } else {
        ticketStatus.style.display = '';
        ticketStatus.style.color   = '#dc3545';
        ticketStatus.innerHTML     = `<i class="bi bi-exclamation-triangle-fill me-1"></i>No se pudo imprimir: ${data.ticket_error || 'error desconocido'}.`;
        btnTicket.style.display    = '';
        const w    = 460, h = 680;
        const left = Math.round((screen.width  - w) / 2);
        const top  = Math.round((screen.height - h) / 2);
        btnTicket.onclick = () => window.open(
          `${URL_TICKET}${data.venta_id}/`, 'ticket',
          `width=${w},height=${h},left=${left},top=${top},scrollbars=yes,toolbar=no,menubar=no,location=no`
        );
      }
    } else {
      ticketStatus.style.display = 'none';
      btnTicket.style.display    = 'none';
    }

    modalPostCobro.show();
  }

  document.getElementById('pc-btn-nueva').addEventListener('click', () => {
    location.reload();
  });

  // ── Hook global: llamado desde base.html al actualizar tasa ──
  window.onTasaActualizada = function(nuevaTasa) {
    TASA = nuevaTasa;

    // Recalcular Bs en todas las tarjetas visibles del grid
    document.querySelectorAll('.producto-card').forEach(card => {
      const precioUsd = parseFloat(card.dataset.precio);
      const bsEl      = card.querySelector('.precio-bs');
      if (bsEl && precioUsd) {
        const sufijo = card.dataset.porPeso === 'true' ? '/kg' : '';
        bsEl.textContent = `Bs. ${(precioUsd * TASA).toFixed(2)}${sufijo}`;
      }
    });

    // Recalcular totales del carrito con la nueva tasa
    renderCarrito();
  };

  // Estado inicial al cargar
  mostrarEstado('inicial');

  // ── Polling de tasa BCV (cada 60 s) ───────────────────────
  const URL_TASA_ESTADO = "/tasa-estado/";
  let tasaVencida = TASA_VENCIDA;

  function aplicarEstadoTasa(vencida, tasa, ultimaAct) {
    if (vencida === tasaVencida && (!tasa || tasa === TASA)) return; // sin cambios

    tasaVencida = vencida;
    if (tasa) {
      TASA = tasa;
      window.onTasaActualizada(tasa); // recalcula tarjetas y carrito
    }

    const alerta    = document.getElementById('alerta-tasa-vencida');
    const btnCobrar = document.getElementById('btn-cobrar');
    const badgeTasa = document.getElementById('badge-tasa-cajero');

    if (alerta) alerta.style.display = vencida ? '' : 'none';

    if (btnCobrar) {
      if (vencida) {
        btnCobrar.disabled = true;
        btnCobrar.innerHTML = '<i class="bi bi-lock me-2"></i>Tasa vencida';
      } else {
        const hayItems = Object.keys(carrito).length > 0;
        btnCobrar.disabled  = !hayItems;
        btnCobrar.innerHTML = '<i class="bi bi-cash-coin me-2"></i>Cobrar';
      }
    }

    if (badgeTasa) {
      if (vencida) {
        badgeTasa.className = 'badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1';
        badgeTasa.innerHTML = '<i class="bi bi-exclamation-triangle-fill me-1"></i>Tasa vencida';
      } else if (tasa) {
        badgeTasa.className = 'badge bg-success-subtle text-success border border-success-subtle px-2 py-1';
        badgeTasa.innerHTML = `<i class="bi bi-currency-dollar me-1"></i>Tasa BCV: Bs. ${tasa.toFixed(2)}`;
      }
      const spanUltAct = document.getElementById('badge-ultima-act');
      if (spanUltAct && ultimaAct) spanUltAct.textContent = `Actualizada: ${ultimaAct}`;
    }
  }

  setInterval(() => {
    fetch(URL_TASA_ESTADO)
      .then(r => r.json())
      .then(d => aplicarEstadoTasa(d.tasa_vencida, d.tasa, d.ultima_actualizacion))
      .catch(() => {}); // silencioso si falla la red
  }, 60_000);

  // Recarga automática cuando el admin actualiza la tasa desde configuración
  // (funciona entre pestañas del mismo origen via Storage Event API)
  window.addEventListener('storage', e => {
    if (e.key === 'pos_tasa_actualizada') location.reload();
  });

  // ── Lector de código de barras global ─────────────────────
  // El escáner escribe muy rápido (~10-30ms entre teclas). Si detectamos
  // una ráfaga rápida de ≥6 chars terminada en Enter, lo tratamos como
  // un escaneo aunque el buscador no tenga el foco.
  (function () {
    let buf = '';
    let t0  = 0;
    const VELOCIDAD_MS = 50;
    const MIN_CHARS    = 6;

    document.addEventListener('keydown', function (e) {
      // Si hay algún modal abierto, no interferir
      if (document.querySelector('.modal.show')) { buf = ''; return; }

      const activo = document.activeElement;

      // Si el foco está en un input crítico que no es el buscador, ignorar
      const inputsCriticos = ['monto-recibido'];
      if (activo && inputsCriticos.includes(activo.id)) { buf = ''; return; }

      // Si el foco está en el buscador, el listener propio del buscador ya maneja Enter.
      // Sólo acumulamos el buffer para detectar velocidad de escáner.
      if (activo && activo.id === 'buscador') {
        const ahora = Date.now();
        if (e.key === 'Enter') { buf = ''; return; }
        if (buf.length > 0 && ahora - t0 > VELOCIDAD_MS) buf = '';
        if (e.key.length === 1) { buf += e.key; t0 = ahora; }
        return;
      }

      const ahora = Date.now();

      if (e.key === 'Enter') {
        if (buf.length >= MIN_CHARS) {
          // Escáner detectado: enrutar al buscador y buscar de inmediato
          e.preventDefault();
          buscador.value = buf;
          buscador.focus();
          clearTimeout(timerBusqueda);
          buscar(buf, true, catSeleccionada);
        }
        buf = ''; return;
      }

      // Resetear buffer si la pausa fue demasiado larga (escritura humana)
      if (buf.length > 0 && ahora - t0 > VELOCIDAD_MS) buf = '';

      if (e.key.length === 1) { buf += e.key; t0 = ahora; }
    });
  })();
</script>

