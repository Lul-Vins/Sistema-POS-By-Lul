    border-left: 3px solid #dc3545;
    background: #fff5f5;
    padding-left: calc(0.6rem - 3px);
  }

  .carrito-item .stock-alerta {
    font-size: .68rem;
    color: #dc3545;
    line-height: 1.3;
    margin-top: 1px;
    width: 100%;
