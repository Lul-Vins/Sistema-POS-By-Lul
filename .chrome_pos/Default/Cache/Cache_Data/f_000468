    flex: 1;
    overflow-y: auto;
    padding-right: 4px;
    padding-top: 6px; /* buffer para que la sombra no se corte */
  }

  .producto-card {
    cursor: pointer;
    border: 2px solid transparent;
    border-radius: 12px;
    /* Sin translateY: evita colisión con la barra de búsqueda */
