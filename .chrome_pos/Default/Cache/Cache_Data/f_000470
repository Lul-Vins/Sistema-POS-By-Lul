      color: #ffffff;
    }

    /* Badge de tasa — clickeable */
    .tasa-badge {
      background-color: #2d6a4f;
      color: #fff;
      font-size: 0.85rem;
      padding: 4px 12px;
      border-radius: 20px;
      font-weight: 600;
      cursor: pointer;
      border: none;
      transition: background-color 0.15s;
      display: flex;
      align-items: center;
      gap: 5px;
    }
    .tasa-badge:hover {
      background-color: #1b4332;
    }
    .tasa-badge.sin-tasa {
      background-color: #842029;
    }
    .tasa-badge .bi-pencil-fill {
      font-size: 0.7rem;
      opacity: 0.8;
    }

    /* ── Botón apagar ──────────────────────────────────────── */
    .btn-apagar {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      border: 1.5px solid rgba(220, 53, 69, 0.45);
      background: transparent;
      color: rgba(220, 53, 69, 0.75);
      font-size: 1rem;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: background .15s, border-color .15s, color .15s;
      padding: 0;
      flex-shrink: 0;
    }
    .btn-apagar:hover {
      background: rgba(220, 53, 69, 0.15);
      border-color: #dc3545;
      color: #dc3545;
    }

    /* ── Contenido principal ───────────────────────────────── */
    .content-wrapper {
      padding-top: 1.5rem;
      padding-bottom: 2rem;
    }

    /* ── Modal de tasa ─────────────────────────────────────── */
