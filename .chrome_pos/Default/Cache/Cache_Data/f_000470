    text-align: center; color: #adb5bd; padding: 3rem 0;
  }
  .sin-productos i { font-size: 3rem; display: block; margin-bottom: .5rem; }

  /* Tabla scroll */
  .tabla-wrap {
    background: #fff; border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0,0,0,.07);
    overflow: hidden;
    max-height: calc(100vh - 220px);
    overflow-y: auto;
  }
</style>

