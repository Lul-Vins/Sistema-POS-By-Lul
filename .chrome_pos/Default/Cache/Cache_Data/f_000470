  /* Estados de fila */
  .fila-agotado   { background: #fff5f5 !important; }
  .fila-stock-bajo { background: #fffbea !important; }
  .fila-inactivo  { opacity: .5; }

  /* Badge de estado */
  .badge-ok        { background: #d1fae5; color: #065f46; font-size: .72rem; }
  .badge-stock-bajo { background: #fef3c7; color: #92400e; font-size: .72rem; }
  .badge-agotado   { background: #fee2e2; color: #991b1b; font-size: .72rem; }
  .badge-inactivo  { background: #e9ecef; color: #6c757d; font-size: .72rem; }

  /* Margen */
  .margen-alto   { color: #065f46; font-weight: 700; }
  .margen-medio  { color: #92400e; font-weight: 600; }
  .margen-bajo   { color: #dc3545; font-weight: 600; }

  /* Imagen miniatura */
  .img-mini {
    width: 38px; height: 38px;
    object-fit: contain;
    border-radius: 6px;
    border: 1px solid #e9ecef;
    background: #f8f9fa;
  }
  .img-mini-placeholder {
    width: 38px; height: 38px;
    border-radius: 6px;
    border: 1px solid #e9ecef;
    background: #f8f9fa;
    display: flex; align-items: center; justify-content: center;
    color: #ced4da; font-size: 1rem;
  }

  /* Contadores de estado */
  .resumen-bar {
    display: flex; gap: 1rem; flex-wrap: wrap;
    margin-bottom: .75rem;
    font-size: .82rem;
    color: #6c757d;
  }
  .resumen-bar span strong { color: #1a1a2e; }
  .resumen-bar .alerta { color: #dc3545; }
  .resumen-bar .advertencia { color: #92400e; }

