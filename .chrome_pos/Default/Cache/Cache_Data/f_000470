  .filtro-btn.agotados.activo   { background: #dc3545; border-color: #dc3545; }

  /* ── Tabla ───────────────────────────────────────────────── */
  .tabla-inv { font-size: .88rem; }
  .tabla-inv thead th {
    background: #1a1a2e;
    color: #fff;
    font-weight: 600;
    font-size: .82rem;
