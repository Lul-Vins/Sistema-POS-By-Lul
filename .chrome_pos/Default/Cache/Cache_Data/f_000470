    /* ── Tipografía global ─────────────────────────────────── */
    body {
      font-family: 'Segoe UI', system-ui, sans-serif;
      font-size: 1.05rem;
      background-color: #f4f6f9;
    }

    /* ── Navbar ────────────────────────────────────────────── */
    .navbar-pos {
      background-color: #1a1a2e;
      min-height: 58px;
    }
    .navbar-pos .navbar-brand {
      font-size: 1.3rem;
      font-weight: 700;
      color: #ffffff;
      letter-spacing: 0.5px;
    }
    .navbar-pos .nav-link {
      color: #c8cdd8;
      font-size: 0.95rem;
    }
    .navbar-pos .nav-link:hover,
