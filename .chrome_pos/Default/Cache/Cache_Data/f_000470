    font-size: .75rem; font-weight: 700; color: #6c757d;
    text-transform: uppercase; letter-spacing: .5px;
    border-bottom: 1px solid #e9ecef; padding-bottom: .3rem;
    margin-bottom: .75rem; margin-top: .5rem;
  }
  .campo-escaneado {
    border-color: #2d6a4f !important;
    box-shadow: 0 0 0 3px rgba(45,106,79,0.2) !important;
    transition: border-color .1s, box-shadow .1s;
  }
  .preview-imagen {
    width: 80px; height: 80px;
    object-fit: contain; border-radius: 8px;
    border: 2px solid #e9ecef; background: #f8f9fa;
    display: none;
  }
  .btn-eliminar-prod {
    color: #dc3545; background: none; border: 1px solid #dc3545;
    border-radius: 8px; padding: .35rem 1rem; font-size: .85rem;
    transition: all .15s;
  }
  .btn-eliminar-prod:hover { background: #dc3545; color: #fff; }

  /* Sin productos */
