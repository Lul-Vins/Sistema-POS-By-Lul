  <script>
    // ── Modal de tasa BCV ───────────────────────────────────
    const URL_ACTUALIZAR_TASA = "/configuracion/tasa/actualizar/";
    const CSRF_TOKEN = "Oys693C9Fw4G9N4tckGyzIVkREw8V6JpDM2OqtWwHPDQomTN6wvGCexdfooh3B6w";

    const inputTasa   = document.getElementById('input-nueva-tasa');
    const btnGuardar  = document.getElementById('btn-guardar-tasa');
    const feedback    = document.getElementById('tasa-feedback');

    // Limpiar feedback al abrir el modal
    document.getElementById('modalTasa').addEventListener('show.bs.modal', () => {
      feedback.textContent = '';
      feedback.className   = 'feedback mt-2';
      inputTasa.value      = '';
      inputTasa.focus();
    });

    // Focus al input cuando el modal termina de abrir
    document.getElementById('modalTasa').addEventListener('shown.bs.modal', () => {
      inputTasa.focus();
    });

    // Guardar con Enter
    inputTasa.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') btnGuardar.click();
    });

    btnGuardar.addEventListener('click', () => {
      const valor = parseFloat(inputTasa.value);

      if (!valor || valor <= 0) {
        mostrarFeedback('Ingresa una tasa válida mayor a 0.', 'error');
        return;
      }

      btnGuardar.disabled = true;
      btnGuardar.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Guardando...';

      fetch(URL_ACTUALIZAR_TASA, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRFToken': CSRF_TOKEN,
        },
        body: JSON.stringify({ tasa: valor }),
      })
        .then(r => r.json())
        .then(data => {
          if (data.ok) {
            // Actualizar navbar y display del modal sin recargar
            const textoTasa = `1 = Bs. ${data.tasa.toFixed(2)}`;
            document.getElementById('tasa-navbar-texto').textContent = textoTasa;
            document.getElementById('btn-abrir-tasa').classList.remove('sin-tasa');
            document.getElementById('tasa-actual-display').textContent = `Bs. ${data.tasa.toFixed(2)}`;
            document.getElementById('ultima-act').textContent = `Última actualización: ${data.ultima_actualizacion}`;

            // Notificar a la página activa para que recalcule precios y carrito
            if (typeof window.onTasaActualizada === 'function') {
              window.onTasaActualizada(data.tasa);
            }

            // Notificar a otras pestañas (ej. el POS abierto por el cajero)
            // para que recarguen y desbloqueen el carrito automáticamente.
            localStorage.setItem('pos_tasa_actualizada', Date.now());

            mostrarFeedback('Tasa actualizada correctamente.', 'ok');

            // Cerrar el modal tras 1 segundo
            setTimeout(() => {
              bootstrap.Modal.getInstance(document.getElementById('modalTasa')).hide();
            }, 1000);
          } else {
            mostrarFeedback(data.error || 'Error al guardar.', 'error');
          }
        })
        .catch(() => mostrarFeedback('Error de conexión.', 'error'))
        .finally(() => {
          btnGuardar.disabled = false;
          btnGuardar.innerHTML = '<i class="bi bi-check-lg me-1"></i>Guardar tasa';
        });
    });

    function mostrarFeedback(msg, tipo) {
      feedback.textContent = msg;
      feedback.className   = `feedback mt-2 ${tipo === 'ok' ? 'text-success' : 'text-danger'}`;
    }

    // ── Apagar / cerrar la aplicación ────────────────────────
    function apagarApp() {
      if (!confirm('¿Cerrar la aplicación?')) return;
      window.close();
    }
  </script>

  
<script id="inv-cats-json" type="application/json">[{"id": 1, "nombre": "harina", "num": 0}]</script>
<script>
  const TASA_INV         = parseFloat("600,00") || 0;
  const URL_GUARDAR      = "/inventario/guardar/";
  const URL_ELIMINAR     = "/inventario/eliminar/0/".replace('/0/', '/');
  const URL_CREAR_CAT    = "/inventario/categorias/crear/";
  const URL_ELIMINAR_CAT = "/inventario/categorias/eliminar/0/".replace('/0/', '/');
  const CSRF_INV         = "Oys693C9Fw4G9N4tckGyzIVkREw8V6JpDM2OqtWwHPDQomTN6wvGCexdfooh3B6w";

  // Datos de categorías para gestión dinámica
  let cats = JSON.parse(document.getElementById('inv-cats-json').textContent);

  // ── Filtrado client-side ──────────────────────────────────
  const buscador    = document.getElementById('buscador-inv');
  const filtroCat   = document.getElementById('filtro-categoria');
  let   filtroActivo = 'todos';

  document.querySelectorAll('.filtro-btn').forEach(btn => {
    btn.addEventListener('click', function () {
      document.querySelectorAll('.filtro-btn').forEach(b => b.classList.remove('activo'));
      this.classList.add('activo');
      filtroActivo = this.dataset.filtro;
      aplicarFiltros();
    });
  });

  buscador.addEventListener('input', aplicarFiltros);
  filtroCat.addEventListener('change', aplicarFiltros);

  function aplicarFiltros() {
    const q    = buscador.value.trim().toLowerCase();
    const cat  = filtroCat.value;
    const filas = document.querySelectorAll('.fila-producto');
    let vis = 0, stockBajoCount = 0, agotadoCount = 0;

    filas.forEach(fila => {
      const nombre     = fila.dataset.nombre.toLowerCase();
      const catId      = fila.dataset.categoriaId;
      const estado     = fila.dataset.stockEstado;
      const inactivo   = fila.dataset.activo === 'false';

      const matchBusq  = !q || nombre.includes(q);
      const matchCat   = !cat || catId === cat;
      const matchFiltro =
        filtroActivo === 'todos'      ? true :
        filtroActivo === 'stock-bajo' ? (estado === 'stock-bajo') :
        filtroActivo === 'agotados'   ? (estado === 'agotado') :
        filtroActivo === 'inactivos'  ? inactivo : true;

      const mostrar = matchBusq && matchCat && matchFiltro;
      fila.style.display = mostrar ? '' : 'none';

      if (mostrar) {
        vis++;
        if (estado === 'stock-bajo') stockBajoCount++;
        if (estado === 'agotado')    agotadoCount++;
      }
    });

    actualizarResumen(vis, stockBajoCount, agotadoCount);
  }

  function actualizarResumen(total, stockBajo, agotados) {
    const bar = document.getElementById('resumen-bar');
    bar.innerHTML = `
      <span><strong>${total}</strong> producto${total !== 1 ? 's' : ''} mostrado${total !== 1 ? 's' : ''}</span>
      ${stockBajo > 0 ? `<span class="advertencia"><i class="bi bi-exclamation-triangle-fill me-1"></i><strong>${stockBajo}</strong> con stock bajo</span>` : ''}
      ${agotados  > 0 ? `<span class="alerta"><i class="bi bi-x-circle-fill me-1"></i><strong>${agotados}</strong> agotado${agotados !== 1 ? 's' : ''}</span>` : ''}
    `;
  }

  // Inicializar resumen
  aplicarFiltros();

  // ── Modal de producto ─────────────────────────────────────
  const modalProdEl  = document.getElementById('modalProducto');
  const modalProd    = new bootstrap.Modal(modalProdEl);
  const inputCosto   = document.getElementById('prod-costo');
  const inputPrecio  = document.getElementById('prod-precio');

  // Preview margen en tiempo real
  [inputCosto, inputPrecio].forEach(el => el.addEventListener('input', actualizarPreviewMargen));

  function actualizarPreviewMargen() {
    const costo  = parseFloat(inputCosto.value) || 0;
    const precio = parseFloat(inputPrecio.value) || 0;
    const preview = document.getElementById('preview-margen');

    if (precio > 0) {
      preview.style.display = 'block';
      const margen = costo > 0 ? ((precio - costo) / precio * 100).toFixed(1) : null;
      document.getElementById('preview-margen-valor').textContent = margen ? `${margen}%` : '—';
      document.getElementById('preview-precio-bs').textContent = (TASA_INV && costo > 0)
        ? `Bs. ${((precio - costo) * TASA_INV).toFixed(2)}`
        : '—';
    } else {
      preview.style.display = 'none';
    }
  }

  // Preview de imagen
  document.getElementById('prod-imagen').addEventListener('change', function () {
    const file = this.files[0];
    const prev = document.getElementById('preview-imagen');
    if (file) {
      prev.src = URL.createObjectURL(file);
      prev.style.display = 'block';
    } else {
      prev.style.display = 'none';
    }
  });

  function abrirModalNuevo() {
    limpiarModal();
    document.getElementById('modal-producto-titulo').innerHTML =
      '<i class="bi bi-plus-circle me-2"></i>Nuevo producto';
    document.getElementById('btn-eliminar-prod').style.display = 'none';
    modalProd.show();
  }

  function abrirModalEditar(fila) {
    limpiarModal();
    document.getElementById('modal-producto-titulo').innerHTML =
      '<i class="bi bi-pencil me-2"></i>Editar producto';

    document.getElementById('prod-pk').value           = fila.dataset.id;
    document.getElementById('prod-nombre').value       = fila.dataset.nombre;
    document.getElementById('prod-categoria').value    = fila.dataset.categoriaId || '';
    document.getElementById('prod-codigo').value       = fila.dataset.codigo;
    document.getElementById('prod-costo').value        = fila.dataset.costo ? parseFloat(fila.dataset.costo).toFixed(2) : '';
    document.getElementById('prod-precio').value       = parseFloat(fila.dataset.precio).toFixed(2);
    const porPeso = fila.dataset.porPeso === 'true';
    document.getElementById('prod-por-peso').checked   = porPeso;
    aplicarModoPeso(porPeso);
    const stockVal    = parseFloat(fila.dataset.stock);
    const stockMinVal = parseFloat(fila.dataset.stockMin);
    document.getElementById('prod-stock').value     = isNaN(stockVal)    ? 0 : (porPeso ? stockVal.toFixed(3)    : String(Math.round(stockVal)));
    document.getElementById('prod-stock-min').value = isNaN(stockMinVal) ? 5 : (porPeso ? stockMinVal.toFixed(3) : String(Math.round(stockMinVal)));
    document.getElementById('prod-activo').checked     = fila.dataset.activo === 'true';
    document.getElementById('prod-alicuota').value     = fila.dataset.alicuota || 'GENERAL';

    if (fila.dataset.imagen) {
      const prev = document.getElementById('preview-imagen');
      prev.src   = fila.dataset.imagen;
      prev.style.display = 'block';
    }

    actualizarPreviewMargen();
    document.getElementById('btn-eliminar-prod').style.display = 'block';
    modalProd.show();
  }

  function limpiarModal() {
    document.getElementById('prod-pk').value        = '0';
    document.getElementById('prod-nombre').value    = '';
    document.getElementById('prod-categoria').value = '';
    document.getElementById('prod-codigo').value    = '';
    document.getElementById('prod-costo').value     = '';
    document.getElementById('prod-precio').value    = '';
    document.getElementById('prod-stock').value     = '0';
    document.getElementById('prod-stock-min').value = '5';
    document.getElementById('prod-activo').checked   = true;
    document.getElementById('prod-alicuota').value    = 'GENERAL';
    document.getElementById('prod-por-peso').checked  = false;
    aplicarModoPeso(false);
    document.getElementById('prod-imagen').value      = '';
    document.getElementById('preview-imagen').style.display = 'none';
    document.getElementById('preview-margen').style.display = 'none';
    document.getElementById('prod-feedback').textContent    = '';
  }

  function aplicarModoPeso(activo) {
    const stockInput    = document.getElementById('prod-stock');
    const stockMinInput = document.getElementById('prod-stock-min');
    const lbl           = document.getElementById('lbl-unidad-stock');
    if (activo) {
      stockInput.step    = '0.001';
      stockMinInput.step = '0.001';
      lbl.textContent    = '(kg)';
      // Si el valor actual tiene decimales inválidos para entero, dejarlo igual
    } else {
      // Si al desactivar "por peso" había decimales, redondear al entero más cercano
      const v  = parseFloat(stockInput.value);
      const vm = parseFloat(stockMinInput.value);
      if (!isNaN(v))  stockInput.value    = Math.round(v);
      if (!isNaN(vm)) stockMinInput.value = Math.round(vm);
      stockInput.step    = '1';
      stockMinInput.step = '1';
      lbl.textContent    = '';
    }
  }

  document.getElementById('prod-por-peso').addEventListener('change', function () {
    aplicarModoPeso(this.checked);
  });

  // ── Guardar producto ──────────────────────────────────────
  document.getElementById('btn-guardar-prod').addEventListener('click', function () {
    const feedback = document.getElementById('prod-feedback');
    const nombre   = document.getElementById('prod-nombre').value.trim();
    const precio   = document.getElementById('prod-precio').value;

    if (!nombre) {
      feedback.textContent = 'El nombre es obligatorio.';
      document.getElementById('prod-nombre').focus();
      return;
    }
    if (!precio || parseFloat(precio) <= 0) {
      feedback.textContent = 'Ingresa un precio de venta válido.';
      document.getElementById('prod-precio').focus();
      return;
    }

    const porPeso      = document.getElementById('prod-por-peso').checked;
    const stockActualV = document.getElementById('prod-stock').value.trim();
    const stockMinimoV = document.getElementById('prod-stock-min').value.trim();
    const stockActual  = parseFloat(stockActualV);
    const stockMinimo  = parseFloat(stockMinimoV);

    if (stockActualV === '' || isNaN(stockActual) || stockActual < 0) {
      feedback.textContent = 'El stock actual debe ser un número positivo.';
      document.getElementById('prod-stock').focus();
      return;
    }
    if (stockMinimoV === '' || isNaN(stockMinimo) || stockMinimo < 0) {
      feedback.textContent = 'El stock mínimo debe ser un número positivo.';
      document.getElementById('prod-stock-min').focus();
      return;
    }
    if (!porPeso && !Number.isInteger(stockActual)) {
      feedback.textContent = 'Para productos por unidad el stock debe ser un número entero, sin decimales.';
      document.getElementById('prod-stock').focus();
      return;
    }
    if (!porPeso && !Number.isInteger(stockMinimo)) {
      feedback.textContent = 'El stock mínimo debe ser un número entero, sin decimales.';
      document.getElementById('prod-stock-min').focus();
      return;
    }
    if (stockActual > 999999 || stockMinimo > 999999) {
      feedback.textContent = 'El stock está fuera de rango.';
      return;
    }

    const form = new FormData();
    form.append('pk',           document.getElementById('prod-pk').value);
    form.append('nombre',       nombre);
    form.append('categoria_id', document.getElementById('prod-categoria').value);
    form.append('codigo_barras', document.getElementById('prod-codigo').value.trim());
    form.append('costo_usd',    document.getElementById('prod-costo').value);
    form.append('precio_usd',   precio);
    form.append('stock_actual',      document.getElementById('prod-stock').value);
    form.append('stock_minimo',      document.getElementById('prod-stock-min').value);
    form.append('vendido_por_peso',  document.getElementById('prod-por-peso').checked ? 'true' : 'false');
    form.append('activo',            document.getElementById('prod-activo').checked ? 'true' : 'false');
    form.append('alicuota_iva',      document.getElementById('prod-alicuota').value);

    const imgFile = document.getElementById('prod-imagen').files[0];
    if (imgFile) form.append('imagen', imgFile);

    this.disabled   = true;
    this.innerHTML  = '<span class="spinner-border spinner-border-sm me-1"></span>Guardando...';
    feedback.textContent = '';

    fetch(URL_GUARDAR, {
      method:  'POST',
      headers: { 'X-CSRFToken': CSRF_INV },
      body:    form,
    })
      .then(r => r.json())
      .then(data => {
        if (data.ok) {
          modalProd.hide();
          location.reload();
        } else {
          feedback.textContent = data.error || 'Error al guardar.';
        }
      })
      .catch(() => { feedback.textContent = 'Error de conexión.'; })
      .finally(() => {
        this.disabled  = false;
        this.innerHTML = '<i class="bi bi-check-lg me-1"></i>Guardar producto';
      });
  });

  // ── Eliminar producto ─────────────────────────────────────
  document.getElementById('btn-eliminar-prod').addEventListener('click', function () {
    const nombre = document.getElementById('prod-nombre').value;
    if (!confirm(`¿Eliminar "${nombre}"?\n\nSi tiene ventas registradas, será desactivado en lugar de eliminado.`)) return;

    const pk = document.getElementById('prod-pk').value;
    this.disabled = true;

    fetch(`${URL_ELIMINAR}${pk}/`, {
      method:  'POST',
      headers: { 'X-CSRFToken': CSRF_INV },
    })
      .then(r => r.json())
      .then(data => {
        if (data.ok) {
          if (data.advertencia) alert(data.advertencia);
          modalProd.hide();
          location.reload();
        } else {
          document.getElementById('prod-feedback').textContent = data.error || 'Error al eliminar.';
        }
      })
      .catch(() => { document.getElementById('prod-feedback').textContent = 'Error de conexión.'; })
      .finally(() => { this.disabled = false; });
  });

  // Actualizar tasa si se cambia desde el navbar
  window.onTasaActualizada = function(nuevaTasa) {
    location.reload();
  };

  // ── Gestión de Categorías ─────────────────────────────────
  const modalCatsEl = document.getElementById('modalCategorias');
  const modalCats   = new bootstrap.Modal(modalCatsEl);

  function abrirModalCategorias() {
    document.getElementById('nueva-cat-nombre').value = '';
    document.getElementById('cat-feedback').textContent = '';
    renderListaCats();
    modalCats.show();
    setTimeout(() => document.getElementById('nueva-cat-nombre').focus(), 300);
  }

  function renderListaCats() {
    const contenedor = document.getElementById('lista-cats');
    if (cats.length === 0) {
      contenedor.innerHTML = '<p class="text-muted text-center py-3" style="font-size:.88rem;">No hay categorías creadas.</p>';
      return;
    }
    contenedor.innerHTML = cats.map(c => `
      <div class="d-flex align-items-center justify-content-between px-2 py-2
                  border-bottom" style="font-size:.9rem;" id="cat-row-${c.id}">
        <div>
          <span class="fw-semibold">${escHtml(c.nombre)}</span>
          <span class="text-muted ms-2" style="font-size:.78rem;">${c.num} producto${c.num !== 1 ? 's' : ''}</span>
        </div>
        <button class="btn btn-sm btn-outline-danger py-0 px-2"
                style="font-size:.8rem; border-radius:6px;"
                onclick="eliminarCategoria(${c.id}, '${escHtml(c.nombre)}', ${c.num})">
          <i class="bi bi-trash"></i>
        </button>
      </div>`).join('');
  }

  function escHtml(str) {
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function actualizarSelects(nuevasCats) {
    // Actualiza ambos selects: filtro de inventario y modal de producto
    ['filtro-categoria', 'prod-categoria'].forEach(id => {
      const sel = document.getElementById(id);
      if (!sel) return;
      const valActual = sel.value;

      // Reconstruir opciones (conservando la opción vacía de prod-categoria)
      const esProducto = id === 'prod-categoria';
      const opcionVacia = esProducto
        ? '<option value="">Sin categoría</option>'
        : '<option value="">Todas las categorías</option>';

      sel.innerHTML = opcionVacia + nuevasCats.map(c =>
        `<option value="${c.id}">${escHtml(c.nombre)}</option>`
      ).join('');

      // Restaurar selección si sigue existiendo
      if (valActual && nuevasCats.find(c => String(c.id) === valActual)) {
        sel.value = valActual;
      }
    });
  }

  function crearCategoria() {
    const input    = document.getElementById('nueva-cat-nombre');
    const feedback = document.getElementById('cat-feedback');
    const nombre   = input.value.trim();

    if (!nombre) { feedback.textContent = 'Escribe un nombre.'; return; }

    const btn = document.getElementById('btn-crear-cat');
    btn.disabled = true;
    feedback.textContent = '';

    fetch(URL_CREAR_CAT, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRFToken': CSRF_INV },
      body:    JSON.stringify({ nombre }),
    })
      .then(r => r.json())
      .then(data => {
        if (data.ok) {
          input.value = '';
          cats.push({ id: data.id, nombre: data.nombre, num: 0 });
          cats.sort((a, b) => a.nombre.localeCompare(b.nombre));
          renderListaCats();
          actualizarSelects(cats);
        } else {
          feedback.textContent = data.error || 'Error al crear.';
        }
      })
      .catch(() => { feedback.textContent = 'Error de conexión.'; })
      .finally(() => { btn.disabled = false; });
  }

  function eliminarCategoria(id, nombre, numProductos) {
    let msg = `¿Eliminar la categoría "${nombre}"?`;
    if (numProductos > 0) {
      msg += `\n\nTiene ${numProductos} producto${numProductos !== 1 ? 's' : ''} asignado${numProductos !== 1 ? 's' : ''}. Quedarán sin categoría.`;
    }
    if (!confirm(msg)) return;

    fetch(`${URL_ELIMINAR_CAT}${id}/`, {
      method:  'POST',
      headers: { 'X-CSRFToken': CSRF_INV },
    })
      .then(r => r.json())
      .then(data => {
        if (data.ok) {
          cats = cats.filter(c => c.id !== id);
          renderListaCats();
          actualizarSelects(cats);

          // Limpiar filas de la tabla que tenían esta categoría
          document.querySelectorAll(`.fila-producto[data-categoria-id="${id}"]`).forEach(fila => {
            fila.dataset.categoriaId   = '';
            fila.dataset.categoriaNombre = '';
            fila.querySelector('td:nth-child(3)').textContent = '—';
          });

          // Resetear filtro si estaba seleccionando esta categoría
          const filtroCat = document.getElementById('filtro-categoria');
          if (filtroCat.value === String(id)) {
            filtroCat.value = '';
            aplicarFiltros();
          }
        } else {
          alert(data.error || 'Error al eliminar.');
        }
      })
      .catch(() => alert('Error de conexión.'));
  }

  // ── Lector de código de barras global ────────────────────────
  // El scanner teclea todos los caracteres en < 50 ms y manda Enter.
  // Si el modal está abierto y no hay otro campo activo, el código
  // va directo a #prod-codigo sin necesidad de hacer clic en él.
  (function () {
    let buf = '';
    let t0  = 0;
    const VELOCIDAD_MS = 50;
    const MIN_CHARS    = 6;

    document.addEventListener('keydown', function (e) {
      if (!modalProdEl.classList.contains('show')) { buf = ''; return; }

      const ahora = Date.now();

      if (e.key === 'Enter') {
        // Solo actuar si la ráfaga fue rápida (escáner)
        if (buf.length >= MIN_CHARS) {
          const campoCodigo = document.getElementById('prod-codigo');
          campoCodigo.value = buf;
          campoCodigo.classList.add('campo-escaneado');
          setTimeout(() => campoCodigo.classList.remove('campo-escaneado'), 800);
          const nombre = document.getElementById('prod-nombre');
          if (!nombre.value.trim()) nombre.focus();
          else campoCodigo.focus();
        }
        buf = ''; return;
      }

      // Si la pausa entre teclas es mayor a VELOCIDAD_MS → escritura humana,
      // resetear y no acumular (deja que el campo activo maneje el evento)
      if (buf.length > 0 && ahora - t0 > VELOCIDAD_MS) { buf = ''; return; }

      if (e.key.length === 1) { buf += e.key; t0 = ahora; }
    });
  })();
</script>

