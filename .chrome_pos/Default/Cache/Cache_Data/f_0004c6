  <script>
    // ── Modal de tasa BCV ───────────────────────────────────
    const URL_ACTUALIZAR_TASA = "/configuracion/tasa/actualizar/";
    const CSRF_TOKEN = "ylqDyhWP8JOw75Lkj0QQzNKz18YBKRMVS3EBicRNiJNpWw0cF5F9s8inCMrg5Xcr";

    const inputTasa   = document.getElementById('input-nueva-tasa');
    const btnGuardar  = document.getElementById('btn-guardar-tasa');
    const feedback    = document.getElementById('tasa-feedback');

    // Limpiar feedback al abrir el modal
    document.getElementById('modalTasa').addEventListener('show.bs.modal', () => {
      feedback.textContent = '';
      feedback.className   = 'feedback mt-2';
      inputTasa.value      = '';
      inputTasa.focus();
    });

    // Focus al input cuando el modal termina de abrir
    document.getElementById('modalTasa').addEventListener('shown.bs.modal', () => {
      inputTasa.focus();
    });

    // Guardar con Enter
    inputTasa.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') btnGuardar.click();
    });

    btnGuardar.addEventListener('click', () => {
      const valor = parseFloat(inputTasa.value);

      if (!valor || valor <= 0) {
        mostrarFeedback('Ingresa una tasa válida mayor a 0.', 'error');
        return;
      }

      btnGuardar.disabled = true;
      btnGuardar.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Guardando...';

      fetch(URL_ACTUALIZAR_TASA, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRFToken': CSRF_TOKEN,
        },
        body: JSON.stringify({ tasa: valor }),
      })
        .then(r => r.json())
        .then(data => {
          if (data.ok) {
            // Actualizar navbar y display del modal sin recargar
            const textoTasa = `1 = Bs. ${data.tasa.toFixed(2)}`;
            document.getElementById('tasa-navbar-texto').textContent = textoTasa;
            document.getElementById('btn-abrir-tasa').classList.remove('sin-tasa');
            document.getElementById('tasa-actual-display').textContent = `Bs. ${data.tasa.toFixed(2)}`;
            document.getElementById('ultima-act').textContent = `Última actualización: ${data.ultima_actualizacion}`;

            // Notificar a la página activa para que recalcule precios y carrito
            if (typeof window.onTasaActualizada === 'function') {
              window.onTasaActualizada(data.tasa);
            }

            // Notificar a otras pestañas (ej. el POS abierto por el cajero)
            // para que recarguen y desbloqueen el carrito automáticamente.
            localStorage.setItem('pos_tasa_actualizada', Date.now());

            mostrarFeedback('Tasa actualizada correctamente.', 'ok');

            // Cerrar el modal tras 1 segundo
            setTimeout(() => {
              bootstrap.Modal.getInstance(document.getElementById('modalTasa')).hide();
            }, 1000);
          } else {
            mostrarFeedback(data.error || 'Error al guardar.', 'error');
          }
        })
        .catch(() => mostrarFeedback('Error de conexión.', 'error'))
        .finally(() => {
          btnGuardar.disabled = false;
          btnGuardar.innerHTML = '<i class="bi bi-check-lg me-1"></i>Guardar tasa';
        });
    });

    function mostrarFeedback(msg, tipo) {
      feedback.textContent = msg;
      feedback.className   = `feedback mt-2 ${tipo === 'ok' ? 'text-success' : 'text-danger'}`;
    }

    // ── Apagar / cerrar la aplicación ────────────────────────
    function apagarApp() {
      if (!confirm('¿Cerrar la aplicación?')) return;
      window.close();
    }
  </script>

  
<script id="tasa-data" type="application/json">"500.00"</script>
<script>
  const CSRF       = "ylqDyhWP8JOw75Lkj0QQzNKz18YBKRMVS3EBicRNiJNpWw0cF5F9s8inCMrg5Xcr";
  const URL_EDITAR = "/fiados/cliente/1/editar/";
  const URL_VENTA  = "/fiados/cliente/1/venta/";
  const URL_BUSCAR = "/buscar/";
  const TASA_HOY   = JSON.parse(document.getElementById('tasa-data').textContent);

  const modalEditar = new bootstrap.Modal(document.getElementById('modalEditarCliente'));
  const modalVenta  = new bootstrap.Modal(document.getElementById('modalVenta'));
  const modalPago   = new bootstrap.Modal(document.getElementById('modalPago'));


  // ── Expand / collapse fiados ───────────────────────────────────
  function toggleFiado(pk) {
    const body    = document.getElementById('fiado-body-' + pk);
    const chevron = document.getElementById('chevron-' + pk);
    const abierto = body.style.display !== 'none';
    body.style.display      = abierto ? 'none' : '';
    chevron.style.transform = abierto ? '' : 'rotate(180deg)';
  }


  // ══ EDITAR CLIENTE ════════════════════════════════════════════
  function abrirModalEditar() { modalEditar.show(); }

  document.getElementById('btn-guardar-editar').addEventListener('click', function () {
    const feedback = document.getElementById('edit-feedback');
    const nombre   = document.getElementById('edit-nombre').value.trim();
    if (!nombre) { feedback.textContent = 'El nombre es obligatorio.'; return; }

    this.disabled  = true;
    this.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Guardando...';
    feedback.textContent = '';

    fetch(URL_EDITAR, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRFToken': CSRF },
      body: JSON.stringify({
        nombre:    nombre,
        telefono:  document.getElementById('edit-telefono').value.trim(),
        direccion: document.getElementById('edit-direccion').value.trim(),
        notas:     document.getElementById('edit-notas').value.trim(),
        activo:    document.getElementById('edit-activo').checked,
      }),
    })
      .then(r => r.json())
      .then(data => {
        if (data.ok) { location.reload(); }
        else { feedback.textContent = data.error || 'Error al guardar.'; }
      })
      .catch(() => { feedback.textContent = 'Error de conexión.'; })
      .finally(() => {
        this.disabled  = false;
        this.innerHTML = '<i class="bi bi-check-lg me-1"></i>Guardar cambios';
      });
  });


  // ══ NUEVA COMPRA FIADA ═════════════════════════════════════════
  let carrito = [];
  let _kgPendiente = null;

  function abrirModalVenta() {
    carrito = [];
    _kgPendiente = null;
    document.getElementById('venta-buscar').value             = '';
    document.getElementById('venta-notas').value              = '';
    document.getElementById('venta-feedback').textContent     = '';
    document.getElementById('venta-resultados').style.display = 'none';
    document.getElementById('kg-inline').style.display        = 'none';
    renderCarrito();
    modalVenta.show();
    setTimeout(() => document.getElementById('venta-buscar').focus(), 300);
  }

  let buscarTimer;
  document.getElementById('venta-buscar').addEventListener('input', function () {
    clearTimeout(buscarTimer);
    const q = this.value.trim();
    if (q.length < 2) { document.getElementById('venta-resultados').style.display = 'none'; return; }
    buscarTimer = setTimeout(() => buscarProductos(q), 250);
  });

  function buscarProductos(q) {
    fetch(URL_BUSCAR + '?q=' + encodeURIComponent(q))
      .then(r => r.json())
      .then(data => {
        const cont = document.getElementById('venta-resultados');
        if (!data.productos.length) {
          cont.innerHTML = '<div class="p-2 text-muted" style="font-size:.85rem;">Sin resultados.</div>';
        } else {
          cont.innerHTML = data.productos.map(p => {
            const sufijo     = p.vendido_por_peso ? '/kg' : '';
            const stockFmt   = p.vendido_por_peso
              ? parseFloat(p.stock_actual.toFixed(3)).toString().replace('.', ',') + ' kg'
              : p.stock_actual;
            const bsStr = TASA_HOY
              ? `Bs. ${(p.precio_usd * TASA_HOY).toFixed(2)}${sufijo} <span class="text-muted" style="font-size:.78rem;">· $${p.precio_usd.toFixed(2)}${sufijo}</span>`
              : `$${p.precio_usd.toFixed(2)}${sufijo}`;
            return `<div class="producto-resultado" onclick='seleccionarProducto(${JSON.stringify(p)})'>
              <span>${p.nombre} <span class="text-muted" style="font-size:.78rem;">stock: ${stockFmt}</span></span>
              <span class="fw-semibold text-success">${bsStr}</span>
            </div>`;
          }).join('');
        }
        cont.style.display = '';
      })
      .catch(() => {});
  }

  function seleccionarProducto(p) {
    document.getElementById('venta-resultados').style.display = 'none';
    document.getElementById('venta-buscar').value = '';

    if (p.vendido_por_peso) {
      _kgPendiente = p;
      const existente = carrito.find(i => i.id === p.id);
      document.getElementById('kg-inline-nombre').textContent =
        p.nombre + (existente ? ` (actual: ${parseFloat(existente.cantidad.toFixed(3)).toString().replace('.', ',')} kg)` : '');
      document.getElementById('kg-inline-input').value           = existente ? existente.cantidad.toFixed(3) : '';
      document.getElementById('kg-inline-feedback').textContent  = '';
      document.getElementById('kg-inline').style.display         = '';
      setTimeout(() => {
        const inp = document.getElementById('kg-inline-input');
        inp.focus(); inp.select();
      }, 80);
      return;
    }

    const existing = carrito.find(i => i.id === p.id);
    if (existing) { existing.cantidad++; }
    else { carrito.push({ id: p.id, nombre: p.nombre, precio_usd: p.precio_usd, cantidad: 1, por_peso: false, stock: p.stock_actual }); }
    renderCarrito();
    document.getElementById('venta-buscar').focus();
  }

  // Confirmar cantidad kg inline
  function confirmarKgInline() {
    const raw = document.getElementById('kg-inline-input').value.trim();
    const val = parseFloat(raw);
    const fb  = document.getElementById('kg-inline-feedback');
    if (raw === '' || isNaN(val))  { fb.textContent = 'Ingresa una cantidad válida.'; return; }
    if (val < 0.001)               { fb.textContent = 'La cantidad mínima es 0,001 kg (1 gramo).'; return; }
    if (val > 9999)                { fb.textContent = 'Máximo 9.999 kg.'; return; }

    const p       = _kgPendiente;
    const cantidad = parseFloat(val.toFixed(3));

    document.getElementById('kg-inline').style.display = 'none';
    _kgPendiente = null;

    const stock    = p.stock_actual ?? p.stock ?? Infinity;
    const existing = carrito.find(i => i.id === p.id);
    if (existing) { existing.cantidad = cantidad; }
    else { carrito.push({ id: p.id, nombre: p.nombre, precio_usd: p.precio_usd, cantidad, por_peso: true, stock }); }

    renderCarrito();
    document.getElementById('venta-buscar').focus();
  }

  document.getElementById('btn-kg-inline-ok').addEventListener('click', confirmarKgInline);

  // Protección del input kg: bloquea e/E/+/- (notación científica y signos)
  document.getElementById('kg-inline-input').addEventListener('keydown', e => {
    if (e.key === 'Enter') { confirmarKgInline(); return; }
    if (['e', 'E', '+', '-'].includes(e.key)) { e.preventDefault(); }
  });

  // Protección del input kg: limpia valores pegados desde el portapapeles
  document.getElementById('kg-inline-input').addEventListener('paste', e => {
    e.preventDefault();
    const texto   = (e.clipboardData || window.clipboardData).getData('text');
    const limpio  = texto.replace(',', '.').replace(/[^\d.]/g, '');
    const val     = parseFloat(limpio);
    if (!isNaN(val) && val > 0 && val <= 9999) {
      document.getElementById('kg-inline-input').value = val.toFixed(3);
    }
  });

  // Protección del input kg: recorta en tiempo real si supera el máximo y avisa de stock
  document.getElementById('kg-inline-input').addEventListener('input', function () {
    const val = parseFloat(this.value);
    const fb  = document.getElementById('kg-inline-feedback');
    if (!isNaN(val) && val > 9999) this.value = '9999';
    if (this.value === '' || isNaN(val) || val <= 0) { fb.textContent = ''; return; }
    const stock = _kgPendiente ? (_kgPendiente.stock_actual ?? _kgPendiente.stock ?? null) : null;
    if (stock !== null && stock !== Infinity && val > stock) {
      const stockFmt = parseFloat(stock.toFixed(3)).toString().replace('.', ',');
      fb.textContent = `⚠ Stock disponible: ${stockFmt} kg`;
      fb.style.color = '#dc3545';
    } else {
      fb.textContent = '';
    }
  });

  document.getElementById('btn-kg-inline-cancelar').addEventListener('click', () => {
    document.getElementById('kg-inline').style.display = 'none';
    _kgPendiente = null;
    document.getElementById('venta-buscar').focus();
  });

  function cambiarCantidad(id, delta) {
    const idx = carrito.findIndex(i => i.id === id);
    if (idx < 0) return;
    const paso = carrito[idx].por_peso ? 0.1 : 1;
    carrito[idx].cantidad = parseFloat((carrito[idx].cantidad + delta * paso).toFixed(3));
    if (carrito[idx].cantidad <= 0) carrito.splice(idx, 1);
    renderCarrito();
  }

  function editarKgCarrito(id) {
    const item = carrito.find(i => i.id === id);
    if (!item) return;
    _kgPendiente = { id: item.id, nombre: item.nombre, precio_usd: item.precio_usd, vendido_por_peso: true, stock: item.stock };
    document.getElementById('kg-inline-nombre').textContent    = item.nombre;
    document.getElementById('kg-inline-input').value           = item.cantidad.toFixed(3);
    document.getElementById('kg-inline-feedback').textContent  = '';
    document.getElementById('kg-inline').style.display         = '';
    setTimeout(() => {
      const inp = document.getElementById('kg-inline-input');
      inp.focus(); inp.select();
    }, 80);
  }

  function renderCarrito() {
    const section = document.getElementById('carrito-section');
    const vacio   = document.getElementById('carrito-vacio');
    const itemsEl = document.getElementById('carrito-items');
    const totalEl = document.getElementById('carrito-total');

    if (!carrito.length) { section.style.display = 'none'; vacio.style.display = ''; return; }
    section.style.display = '';
    vacio.style.display   = 'none';

    let totalUsd = 0;
    itemsEl.innerHTML = carrito.map(i => {
      const sub      = i.precio_usd * i.cantidad;
      totalUsd      += sub;
      const subBs    = TASA_HOY ? `<span class="monto-bs">Bs. ${(sub * TASA_HOY).toFixed(2)}</span> ` : '';
      const sinStock = typeof i.stock === 'number' && i.stock !== Infinity && i.cantidad > i.stock;
      const stockFmt = sinStock
        ? (i.por_peso
            ? parseFloat(i.stock.toFixed(3)).toString().replace('.', ',') + ' kg'
            : i.stock)
        : null;

      const cantDisplay = i.por_peso
        ? parseFloat(i.cantidad.toFixed(3)).toString().replace('.', ',') + ' kg'
        : i.cantidad;
      const cantSpan = i.por_peso
        ? `<span class="fw-semibold" onclick="editarKgCarrito(${i.id})" title="Clic para editar"
                style="min-width:3.5rem; text-align:center; font-size:.88rem; cursor:pointer;
                       background:${sinStock ? '#fee2e2' : '#f0fdf4'}; border-radius:4px; padding:1px 5px;
                       color:${sinStock ? '#dc3545' : '#1b4332'};">${cantDisplay}</span>`
        : `<span class="fw-semibold" style="min-width:3rem; text-align:center; font-size:.88rem;
                  color:${sinStock ? '#dc3545' : 'inherit'};">${cantDisplay}</span>`;

      const alertaHtml = sinStock
        ? `<div style="width:100%; font-size:.75rem; color:#dc3545; padding:.15rem .25rem 0;">
             <i class="bi bi-exclamation-triangle-fill me-1"></i>Sin stock suficiente — disponible: ${stockFmt}
           </div>`
        : '';

      return `<div class="carrito-item" style="flex-wrap:wrap; ${sinStock ? 'background:#fff5f5; border:1px solid #fca5a5;' : ''}">
        <button class="btn btn-outline-secondary btn-sm py-0 px-2" onclick="cambiarCantidad(${i.id},-1)">−</button>
        ${cantSpan}
        <button class="btn btn-outline-secondary btn-sm py-0 px-2" onclick="cambiarCantidad(${i.id},1)">+</button>
        <span class="flex-grow-1 ms-2">${i.nombre}</span>
        ${subBs}<span class="text-muted" style="font-size:.82rem;">$${sub.toFixed(2)}</span>
        ${alertaHtml}
      </div>`;
    }).join('');

    const hayErrorStock = carrito.some(i => typeof i.stock === 'number' && i.stock !== Infinity && i.cantidad > i.stock);
    const btnConfirmar  = document.getElementById('btn-confirmar-venta');
    btnConfirmar.disabled = hayErrorStock;
    document.getElementById('venta-feedback').textContent = hayErrorStock
      ? 'Corrige las cantidades en rojo antes de confirmar.'
      : '';

    const bsTotal = TASA_HOY
      ? `<span class="text-success">Bs. ${(totalUsd * TASA_HOY).toFixed(2)}</span> <span class="text-muted fw-normal" style="font-size:.85rem;">($ ${totalUsd.toFixed(2)} USD)</span>`
      : `<span class="text-success">$${totalUsd.toFixed(2)} USD</span>`;
    totalEl.innerHTML = `Total: ${bsTotal}`;
  }

  document.getElementById('btn-confirmar-venta').addEventListener('click', function () {
    const feedback = document.getElementById('venta-feedback');
    if (!carrito.length) { feedback.textContent = 'Agrega al menos un producto.'; return; }

    this.disabled  = true;
    this.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Registrando...';
    feedback.textContent = '';

    fetch(URL_VENTA, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRFToken': CSRF },
      body: JSON.stringify({
        carrito: carrito.map(i => ({ id: i.id, cantidad: i.cantidad })),
        notas:   document.getElementById('venta-notas').value.trim(),
      }),
    })
      .then(r => r.json())
      .then(data => {
        if (data.ok) { location.reload(); }
        else { feedback.textContent = data.error || 'Error al registrar.'; }
      })
      .catch(() => { feedback.textContent = 'Error de conexión.'; })
      .finally(() => {
        this.disabled  = false;
        this.innerHTML = '<i class="bi bi-check-lg me-1"></i>Confirmar fiado';
      });
  });


  // ══ REGISTRAR ABONO ═══════════════════════════════════════════
  // saldoUsd: deuda fija en USD
  // saldoBsHoy: Bs equivalentes HOY (= saldoUsd × tasa_hoy), puede estar vacío si no hay tasa
  function abrirModalPago(fiadoPk, saldoUsd, saldoBsHoy) {
    const sUsd = parseFloat(saldoUsd);
    const sBs  = saldoBsHoy ? parseFloat(saldoBsHoy) : null;

    document.getElementById('pago-fiado-pk').value  = fiadoPk;
    document.getElementById('pago-saldo-usd').value = sUsd;

    if (sBs && TASA_HOY) {
      document.getElementById('pago-bs-display').textContent  = `Bs. ${sBs.toFixed(2)}`;
      document.getElementById('pago-usd-display').textContent = `≡ $${sUsd.toFixed(2)} USD · tasa ${TASA_HOY}`;
    } else {
      document.getElementById('pago-bs-display').textContent  = `$${sUsd.toFixed(2)} USD`;
      document.getElementById('pago-usd-display').textContent = '';
    }

    // Resetear: el método va primero, el monto se pre-llena al seleccionar
    document.getElementById('pago-metodo').value           = '';
    document.getElementById('pago-monto').value            = '';
    document.getElementById('pago-notas').value            = '';
    document.getElementById('pago-feedback').textContent   = '';
    document.getElementById('pago-equiv').style.display    = 'none';
    document.getElementById('pago-equiv-txt').textContent  = '';
    document.getElementById('pago-monto-label').innerHTML  = 'Monto a abonar (Bs) <span class="text-danger">*</span>';
    document.getElementById('pago-monto-prefix').textContent = 'Bs.';

    modalPago.show();
    setTimeout(() => document.getElementById('pago-metodo').focus(), 300);
  }

  // Actualiza label, prefijo y pre-llena el monto según el método elegido
  function actualizarCampoMonto(metodo) {
    const sUsd   = parseFloat(document.getElementById('pago-saldo-usd').value);
    const label  = document.getElementById('pago-monto-label');
    const prefix = document.getElementById('pago-monto-prefix');
    const input  = document.getElementById('pago-monto');

    if (metodo === 'EFECTIVO_USD') {
      label.innerHTML      = 'Monto a abonar (USD) <span class="text-danger">*</span>';
      prefix.textContent   = '$';
      input.value          = sUsd.toFixed(2);
    } else {
      label.innerHTML      = 'Monto a abonar (Bs) <span class="text-danger">*</span>';
      prefix.textContent   = 'Bs.';
      input.value          = TASA_HOY ? (sUsd * TASA_HOY).toFixed(2) : sUsd.toFixed(2);
    }

    document.getElementById('pago-equiv').style.display   = 'none';
    document.getElementById('pago-equiv-txt').textContent = '';
    if (metodo) { input.focus(); input.select(); }
  }

  document.getElementById('pago-metodo').addEventListener('change', function () {
    actualizarCampoMonto(this.value);
  });

  // Preview en tiempo real del equivalente en la otra moneda
  document.getElementById('pago-monto').addEventListener('input', function () {
    const equiv    = document.getElementById('pago-equiv');
    const equivTxt = document.getElementById('pago-equiv-txt');
    const metodo   = document.getElementById('pago-metodo').value;
    const monto    = parseFloat(this.value);

    if (!TASA_HOY || !monto || monto <= 0) { equiv.style.display = 'none'; return; }

    if (metodo === 'EFECTIVO_USD') {
      equivTxt.textContent = `≡ Bs. ${(monto * TASA_HOY).toFixed(2)}`;
    } else {
      equivTxt.textContent = `≡ $${(monto / TASA_HOY).toFixed(2)} USD`;
    }
    equiv.style.display = '';
  });

  document.getElementById('btn-confirmar-pago').addEventListener('click', function () {
    const feedback = document.getElementById('pago-feedback');
    const fiadoPk  = document.getElementById('pago-fiado-pk').value;
    const monto    = parseFloat(document.getElementById('pago-monto').value);
    const metodo   = document.getElementById('pago-metodo').value;

    if (!monto || isNaN(monto) || monto <= 0) { feedback.textContent = 'Ingresa un monto válido.'; return; }
    if (monto > 99_999_999) { feedback.textContent = 'El monto es demasiado alto.'; return; }
    if (!metodo) { feedback.textContent = 'Selecciona el método de pago.'; return; }

    this.disabled  = true;
    this.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Registrando...';
    feedback.textContent = '';

    const payload = {
      metodo_pago: metodo,
      notas:       document.getElementById('pago-notas').value.trim(),
    };
    // EFECTIVO_USD → monto en dólares; resto → monto en Bs (backend convierte)
    if (metodo === 'EFECTIVO_USD') { payload.monto_usd = monto; }
    else if (TASA_HOY)             { payload.monto_bs  = monto; }
    else                           { payload.monto_usd = monto; }

    fetch(`/fiados/pago/${fiadoPk}/`, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRFToken': CSRF },
      body: JSON.stringify(payload),
    })
      .then(r => r.json())
      .then(data => {
        if (data.ok) { location.reload(); }
        else { feedback.textContent = data.error || 'Error al registrar.'; }
      })
      .catch(() => { feedback.textContent = 'Error de conexión.'; })
      .finally(() => {
        this.disabled  = false;
        this.innerHTML = '<i class="bi bi-check-lg me-1"></i>Registrar abono';
      });
  });

  document.getElementById('pago-monto').addEventListener('keydown', e => {
    if (e.key === 'Enter') document.getElementById('btn-confirmar-pago').click();
  });


  // ── Anular fiado ──────────────────────────────────────────────
  function confirmarAnular(pk) {
    if (!confirm('¿Anular este fiado? Se restaurará el stock de los productos.')) return;
    fetch(`/fiados/anular/${pk}/`, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRFToken': CSRF },
      body: '{}',
    })
      .then(r => r.json())
      .then(data => {
        if (data.ok) { location.reload(); }
        else { alert(data.error || 'Error al anular.'); }
      })
      .catch(() => alert('Error de conexión.'));
  }

  // Recargar cuando el admin actualiza la tasa BCV (misma pestaña o desde otra)
  window.onTasaActualizada = () => location.reload();
  window.addEventListener('storage', e => {
    if (e.key === 'pos_tasa_actualizada') location.reload();
  });
</script>

</body>
