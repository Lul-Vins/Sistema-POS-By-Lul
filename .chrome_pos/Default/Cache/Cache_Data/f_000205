  <script>
    // ── Modal de tasa BCV ───────────────────────────────────
    const URL_ACTUALIZAR_TASA = "/configuracion/tasa/actualizar/";
    const CSRF_TOKEN = "Dpsi8PhGFGrqUvzks69h1sLvvP8Qj0NFI755IY3qnJn98PJjiUy9OhlqWzv8w0QT";

    const inputTasa   = document.getElementById('input-nueva-tasa');
    const btnGuardar  = document.getElementById('btn-guardar-tasa');
    const feedback    = document.getElementById('tasa-feedback');

    // Limpiar feedback al abrir el modal
    document.getElementById('modalTasa').addEventListener('show.bs.modal', () => {
      feedback.textContent = '';
      feedback.className   = 'feedback mt-2';
      inputTasa.value      = '';
      inputTasa.focus();
    });

    // Focus al input cuando el modal termina de abrir
    document.getElementById('modalTasa').addEventListener('shown.bs.modal', () => {
      inputTasa.focus();
    });

    // Guardar con Enter
    inputTasa.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') btnGuardar.click();
    });

    btnGuardar.addEventListener('click', () => {
      const valor = parseFloat(inputTasa.value);

      if (!valor || valor <= 0) {
        mostrarFeedback('Ingresa una tasa válida mayor a 0.', 'error');
        return;
      }

      btnGuardar.disabled = true;
      btnGuardar.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Guardando...';

      fetch(URL_ACTUALIZAR_TASA, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRFToken': CSRF_TOKEN,
        },
        body: JSON.stringify({ tasa: valor }),
      })
        .then(r => r.json())
        .then(data => {
          if (data.ok) {
            // Actualizar navbar y display del modal sin recargar
            const textoTasa = `1 = Bs. ${data.tasa.toFixed(2)}`;
            document.getElementById('tasa-navbar-texto').textContent = textoTasa;
            document.getElementById('btn-abrir-tasa').classList.remove('sin-tasa');
            document.getElementById('tasa-actual-display').textContent = `Bs. ${data.tasa.toFixed(2)}`;
            document.getElementById('ultima-act').textContent = `Última actualización: ${data.ultima_actualizacion}`;

            // Notificar a la página activa para que recalcule precios y carrito
            if (typeof window.onTasaActualizada === 'function') {
              window.onTasaActualizada(data.tasa);
            }

            // Notificar a otras pestañas (ej. el POS abierto por el cajero)
            // para que recarguen y desbloqueen el carrito automáticamente.
            localStorage.setItem('pos_tasa_actualizada', Date.now());

            mostrarFeedback('Tasa actualizada correctamente.', 'ok');

            // Cerrar el modal tras 1 segundo
            setTimeout(() => {
              bootstrap.Modal.getInstance(document.getElementById('modalTasa')).hide();
            }, 1000);
          } else {
            mostrarFeedback(data.error || 'Error al guardar.', 'error');
          }
        })
        .catch(() => mostrarFeedback('Error de conexión.', 'error'))
        .finally(() => {
          btnGuardar.disabled = false;
          btnGuardar.innerHTML = '<i class="bi bi-check-lg me-1"></i>Guardar tasa';
        });
    });

    function mostrarFeedback(msg, tipo) {
      feedback.textContent = msg;
      feedback.className   = `feedback mt-2 ${tipo === 'ok' ? 'text-success' : 'text-danger'}`;
    }

    // ── Apagar / cerrar la aplicación ────────────────────────
    function apagarApp() {
      if (!confirm('¿Cerrar la aplicación?')) return;
      window.close();
    }
  </script>

  
<script>
  const URL_CREAR  = "/fiados/cliente/crear/";
  const CSRF_F     = "Dpsi8PhGFGrqUvzks69h1sLvvP8Qj0NFI755IY3qnJn98PJjiUy9OhlqWzv8w0QT";
  const modalEl    = document.getElementById('modalCliente');
  const modal      = new bootstrap.Modal(modalEl);

  // ── Buscador ──────────────────────────────────────────────────
  document.getElementById('buscador-clientes').addEventListener('input', function () {
    const q = this.value.trim().toLowerCase();
    document.querySelectorAll('#tabla-clientes tbody tr').forEach(tr => {
      const match = !q || tr.dataset.nombre.includes(q) || tr.dataset.tel.includes(q);
      tr.style.display = match ? '' : 'none';
    });
  });

  // ── Modal nuevo cliente ───────────────────────────────────────
  function abrirModalNuevo() {
    document.getElementById('modal-cliente-titulo').innerHTML =
      '<i class="bi bi-person-plus me-2"></i>Nuevo cliente';
    document.getElementById('cliente-pk').value       = '0';
    document.getElementById('cliente-nombre').value   = '';
    document.getElementById('cliente-telefono').value = '';
    document.getElementById('cliente-direccion').value = '';
    document.getElementById('cliente-notas').value    = '';
    document.getElementById('cliente-feedback').textContent = '';
    modal.show();
    setTimeout(() => document.getElementById('cliente-nombre').focus(), 300);
  }

  document.getElementById('btn-guardar-cliente').addEventListener('click', function () {
    guardarCliente(false);
  });

  function guardarCliente(forzar) {
    const btn      = document.getElementById('btn-guardar-cliente');
    const feedback = document.getElementById('cliente-feedback');
    const nombre   = document.getElementById('cliente-nombre').value.trim();

    if (!nombre) {
      feedback.textContent = 'El nombre es obligatorio.';
      document.getElementById('cliente-nombre').focus();
      return;
    }

    btn.disabled  = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Guardando...';
    feedback.textContent = '';

    fetch(URL_CREAR, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRFToken': CSRF_F },
      body: JSON.stringify({
        nombre:    nombre,
        telefono:  document.getElementById('cliente-telefono').value.trim(),
        direccion: document.getElementById('cliente-direccion').value.trim(),
        notas:     document.getElementById('cliente-notas').value.trim(),
        forzar:    forzar,
      }),
    })
      .then(r => r.json())
      .then(data => {
        if (data.ok) {
          modal.hide();
          mostrarBannerExito(data);
          agregarFilaCliente(data);
        } else if (data.advertencia) {
          if (confirm(data.error)) guardarCliente(true);
        } else {
          feedback.textContent = data.error || 'Error al guardar.';
        }
      })
      .catch(() => { feedback.textContent = 'Error de conexión.'; })
      .finally(() => {
        btn.disabled  = false;
        btn.innerHTML = '<i class="bi bi-check-lg me-1"></i>Guardar cliente';
      });
  }

  function mostrarBannerExito(data) {
    // Eliminar banner anterior si existe
    const anterior = document.getElementById('banner-cliente-ok');
    if (anterior) anterior.remove();

    const banner = document.createElement('div');
    banner.id = 'banner-cliente-ok';
    banner.className = 'alert alert-success d-flex align-items-center gap-2 mb-3';
    banner.style.borderRadius = '10px';
    banner.innerHTML = `
      <i class="bi bi-check-circle-fill flex-shrink-0"></i>
      <span>Cliente <strong>${data.nombre}</strong> registrado.
        <a href="${data.url}" class="alert-link ms-1">Ver ficha →</a>
      </span>
      <button type="button" class="btn-close ms-auto" onclick="this.parentElement.remove()"></button>
    `;
    // Insertar arriba de la tabla/buscador
    const buscador = document.getElementById('buscador-clientes');
    buscador.parentElement.insertBefore(banner, buscador.parentElement.firstChild);
    // Auto-cerrar tras 6s
    setTimeout(() => { if (banner.isConnected) banner.remove(); }, 6000);
  }

  function agregarFilaCliente(data) {
    const tbody = document.querySelector('#tabla-clientes tbody');
    if (!tbody) {
      // Primera vez: recargar para mostrar la tabla correctamente
      setTimeout(() => location.reload(), 800);
      return;
    }
    const tr = document.createElement('tr');
    tr.className = 'cliente-row';
    tr.dataset.nombre = data.nombre.toLowerCase();
    tr.dataset.tel    = (data.telefono || '').toLowerCase();
    tr.onclick = () => window.location = data.url;
    tr.style.cssText  = 'background:#f0fdf4; transition:background 2s ease;';
    tr.innerHTML = `
      <td><div class="fw-semibold">${data.nombre}</div></td>
      <td class="text-muted">${data.telefono || '—'}</td>
      <td class="text-end fw-bold"><span class="text-muted">$ 0.00</span></td>
      <td class="text-center text-muted">0</td>
      <td class="text-center"><span class="badge saldo-badge-cero">Al día</span></td>
    `;
    tbody.appendChild(tr);
    // Quitar el verde gradualmente (simula highlight que desaparece)
    requestAnimationFrame(() => {
      requestAnimationFrame(() => { tr.style.background = ''; });
    });
  }

  // Solo dígitos en teléfono
  document.getElementById('cliente-telefono').addEventListener('input', function () {
    this.value = this.value.replace(/\D/g, '');
  });

  // Enter en nombre guarda
  document.getElementById('cliente-nombre').addEventListener('keydown', e => {
    if (e.key === 'Enter') document.getElementById('btn-guardar-cliente').click();
  });

  // Recalcular saldos si el admin actualiza la tasa BCV
  window.onTasaActualizada = () => location.reload();
  window.addEventListener('storage', e => {
    if (e.key === 'pos_tasa_actualizada') location.reload();
  });
</script>

</body>
</html>
