  <script>
    // ── Modal de tasa BCV ───────────────────────────────────
    const URL_ACTUALIZAR_TASA = "/configuracion/tasa/actualizar/";
    const CSRF_TOKEN = "o1pSujqTiO5XaV6102lW22yLHMH95B9KRNux7dO5fTjr3IRoSA2PifcyeXnZ3kB5";

    const inputTasa   = document.getElementById('input-nueva-tasa');
    const btnGuardar  = document.getElementById('btn-guardar-tasa');
    const feedback    = document.getElementById('tasa-feedback');

    // Limpiar feedback al abrir el modal
    document.getElementById('modalTasa').addEventListener('show.bs.modal', () => {
      feedback.textContent = '';
      feedback.className   = 'feedback mt-2';
      inputTasa.value      = '';
      inputTasa.focus();
    });

    // Focus al input cuando el modal termina de abrir
    document.getElementById('modalTasa').addEventListener('shown.bs.modal', () => {
      inputTasa.focus();
    });

    // Guardar con Enter
    inputTasa.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') btnGuardar.click();
    });

    btnGuardar.addEventListener('click', () => {
      const valor = parseFloat(inputTasa.value);

      if (!valor || valor <= 0) {
        mostrarFeedback('Ingresa una tasa válida mayor a 0.', 'error');
        return;
      }

      btnGuardar.disabled = true;
      btnGuardar.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Guardando...';

      fetch(URL_ACTUALIZAR_TASA, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRFToken': CSRF_TOKEN,
        },
        body: JSON.stringify({ tasa: valor }),
      })
        .then(r => r.json())
        .then(data => {
          if (data.ok) {
            // Actualizar navbar y display del modal sin recargar
            const textoTasa = `1 = Bs. ${data.tasa.toFixed(2)}`;
            document.getElementById('tasa-navbar-texto').textContent = textoTasa;
            document.getElementById('btn-abrir-tasa').classList.remove('sin-tasa');
            document.getElementById('tasa-actual-display').textContent = `Bs. ${data.tasa.toFixed(2)}`;
            document.getElementById('ultima-act').textContent = `Última actualización: ${data.ultima_actualizacion}`;

            // Notificar a la página activa para que recalcule precios y carrito
            if (typeof window.onTasaActualizada === 'function') {
              window.onTasaActualizada(data.tasa);
            }

            // Notificar a otras pestañas (ej. el POS abierto por el cajero)
            // para que recarguen y desbloqueen el carrito automáticamente.
            localStorage.setItem('pos_tasa_actualizada', Date.now());

            mostrarFeedback('Tasa actualizada correctamente.', 'ok');

            // Cerrar el modal tras 1 segundo
            setTimeout(() => {
              bootstrap.Modal.getInstance(document.getElementById('modalTasa')).hide();
            }, 1000);
          } else {
            mostrarFeedback(data.error || 'Error al guardar.', 'error');
          }
        })
        .catch(() => mostrarFeedback('Error de conexión.', 'error'))
        .finally(() => {
          btnGuardar.disabled = false;
          btnGuardar.innerHTML = '<i class="bi bi-check-lg me-1"></i>Guardar tasa';
        });
    });

    function mostrarFeedback(msg, tipo) {
      feedback.textContent = msg;
      feedback.className   = `feedback mt-2 ${tipo === 'ok' ? 'text-success' : 'text-danger'}`;
    }

    // ── Apagar / cerrar la aplicación ────────────────────────
    function apagarApp() {
      if (!confirm('¿Cerrar la aplicación?')) return;
      window.close();
    }
  </script>

  
<script>
const CSRF = "o1pSujqTiO5XaV6102lW22yLHMH95B9KRNux7dO5fTjr3IRoSA2PifcyeXnZ3kB5";
const URL_CREAR  = "/configuracion/usuarios/crear/";
const URL_EDITAR = "/configuracion/usuarios/9999/editar/".replace('9999', '{pk}');

const modal       = new bootstrap.Modal(document.getElementById('modalUsuario'));
const inputPass   = document.getElementById('edit-password');
const btnToggle   = document.getElementById('btn-toggle-pass');

btnToggle.addEventListener('click', () => {
  const visible = inputPass.type === 'text';
  inputPass.type = visible ? 'password' : 'text';
  btnToggle.innerHTML = visible ? '<i class="bi bi-eye"></i>' : '<i class="bi bi-eye-slash"></i>';
});

// Enforce username pattern (alphanumeric + underscore only, no spaces)
document.getElementById('edit-username').addEventListener('input', function () {
  this.value = this.value.replace(/[^a-zA-Z0-9_]/g, '');
});

// ── Abrir modal nuevo ──────────────────────────────────────
document.getElementById('btn-nuevo-usuario').addEventListener('click', () => {
  document.getElementById('modal-usuario-titulo').innerHTML = '<i class="bi bi-person-plus-fill me-2"></i>Nuevo usuario';
  document.getElementById('edit-pk').value       = '0';
  document.getElementById('edit-nombre').value   = '';
  document.getElementById('edit-username').value = '';
  document.getElementById('edit-password').value = '';
  document.getElementById('campo-username-wrapper').classList.remove('d-none');
  document.getElementById('lbl-pass-opcional').classList.add('d-none');
  document.getElementById('campo-activo-wrapper').classList.add('d-none');
  document.querySelector('#rol-cajero').checked = true;
  document.getElementById('edit-activo').checked = true;
  document.getElementById('usuario-error').classList.add('d-none');
  modal.show();
});

// ── Abrir modal editar ─────────────────────────────────────
function abrirEditar(pk, nombre, username, esAdmin, activo) {
  document.getElementById('modal-usuario-titulo').innerHTML = '<i class="bi bi-pencil-fill me-2"></i>Editar usuario';
  document.getElementById('edit-pk').value       = pk;
  document.getElementById('edit-nombre').value   = nombre;
  document.getElementById('edit-username').value = username;
  document.getElementById('edit-password').value = '';
  document.getElementById('campo-username-wrapper').classList.add('d-none');
  document.getElementById('lbl-pass-opcional').classList.remove('d-none');
  document.getElementById('campo-activo-wrapper').classList.remove('d-none');
  document.querySelector(esAdmin ? '#rol-admin-radio' : '#rol-cajero').checked = true;
  document.getElementById('edit-activo').checked = activo;
  document.getElementById('usuario-error').classList.add('d-none');
  modal.show();
}

// ── Guardar ────────────────────────────────────────────────
document.getElementById('btn-guardar-usuario').addEventListener('click', async () => {
  const pk       = parseInt(document.getElementById('edit-pk').value);
  const nombre   = document.getElementById('edit-nombre').value.trim();
  const username = document.getElementById('edit-username').value.trim();
  const password = document.getElementById('edit-password').value.trim();
  const esAdmin  = document.querySelector('input[name="edit-rol"]:checked').value === 'admin';
  const activo   = document.getElementById('edit-activo').checked;
  const errDiv   = document.getElementById('usuario-error');

  if (!nombre) { mostrarError('El nombre es obligatorio.'); return; }
  if (pk === 0 && !username) { mostrarError('El nombre de usuario es obligatorio.'); return; }
  if (pk === 0 && !/^[a-zA-Z0-9_]+$/.test(username)) {
    mostrarError('El usuario solo puede contener letras, números y guión bajo.'); return;
  }
  if (pk === 0 && !password) { mostrarError('La contraseña es obligatoria al crear un usuario.'); return; }

  const btn = document.getElementById('btn-guardar-usuario');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Guardando...';

  const url  = pk === 0 ? URL_CREAR : URL_EDITAR.replace('{pk}', pk);
  const body = pk === 0
    ? { nombre, username, password, es_admin: esAdmin }
    : { nombre, password, es_admin: esAdmin, activo };

  try {
    const resp = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRFToken': CSRF },
      body: JSON.stringify(body),
    });
    const data = await resp.json();

    if (data.ok) {
      modal.hide();
      actualizarFila(data, pk === 0);
    } else {
      mostrarError(data.error || 'Error al guardar.');
    }
  } catch {
    mostrarError('Error de conexión.');
  } finally {
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-check-lg me-1"></i>Guardar';
  }
});

function mostrarError(msg) {
  const div = document.getElementById('usuario-error');
  div.textContent = msg;
  div.classList.remove('d-none');
}

function actualizarFila(data, esNuevo) {
  const rolLabel   = data.es_admin ? 'Admin'  : 'Cajero';
  const rolClase   = data.es_admin ? 'rol-admin' : 'rol-cajero';
  const estadoHtml = data.activo
    ? '<span class="badge bg-success-subtle text-success">Activo</span>'
    : '<span class="badge badge-inactivo">Inactivo</span>';

  const nombre    = escHtml(data.nombre);
  const username  = escHtml(data.username);
  const filaHtml  = `
    <td class="fw-semibold">${nombre}</td>
    <td class="text-muted">${username}</td>
    <td><span class="badge rounded-pill ${rolClase}">${rolLabel}</span></td>
    <td>${estadoHtml}</td>
    <td class="text-end">
      <button class="btn btn-outline-primary btn-sm"
        onclick="abrirEditar(${data.id}, '${nombre}', '${username}', ${data.es_admin}, ${data.activo})">
        <i class="bi bi-pencil-fill"></i>
      </button>
    </td>`;

  if (esNuevo) {
    const tbody  = document.getElementById('tabla-usuarios');
    const empty  = tbody.querySelector('[colspan]');
    if (empty) empty.closest('tr').remove();
    const tr = document.createElement('tr');
    tr.id = `fila-${data.id}`;
    tr.innerHTML = filaHtml;
    tbody.appendChild(tr);
  } else {
    const fila = document.getElementById(`fila-${data.id}`);
    if (fila) fila.innerHTML = filaHtml;
  }
}

function escHtml(str) {
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
</script>

</body>
</html>
