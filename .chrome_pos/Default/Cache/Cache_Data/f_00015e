    resultado.innerHTML = '';

    fetch("/configuracion/backup/", {
      method:  'POST',
      headers: { 'X-CSRFToken': 'D3ntlmJaymiYFm5IXFKOQsUptC3sxYqQVVNfgoONkPWYU52Ag8SbvZhdBfRLcqfm' },
    })
      .then(r => r.json())
      .then(data => {
        if (data.ok) {
          resultado.innerHTML =
            `<span class="text-success"><i class="bi bi-check-circle-fill me-1"></i>
             Respaldo guardado en: <strong>${data.ruta}</strong></span>`;
        } else {
          resultado.innerHTML =
            `<span class="text-danger"><i class="bi bi-x-circle-fill me-1"></i>${data.error}</span>`;
        }
      })
      .catch(() => {
        resultado.innerHTML =
          '<span class="text-danger"><i class="bi bi-x-circle-fill me-1"></i>Error de conexión.</span>';
      })
      .finally(() => {
        btn.disabled  = false;
        btn.innerHTML = '<i class="bi bi-download me-1"></i>Hacer respaldo ahora';
      });
  });

  // Preview de logo al seleccionar archivo
  document.getElementById('id_logo').addEventListener('change', function () {
    const file = this.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = e => {
      const img = document.getElementById('logo-img');
      const placeholder = document.getElementById('logo-placeholder');
      img.src = e.target.result;
      img.style.display = 'block';
      if (placeholder) placeholder.style.display = 'none';
    };
    reader.readAsDataURL(file);
  });

  // Solo dígitos en RIF y teléfono
  ['id_rif', 'id_telefono'].forEach(id => {
    document.getElementById(id).addEventListener('input', function () {
      this.value = this.value.replace(/\D/g, '');
    });
  });

  const CSRF             = 'D3ntlmJaymiYFm5IXFKOQsUptC3sxYqQVVNfgoONkPWYU52Ag8SbvZhdBfRLcqfm';
  const URL_TOGGLE       = "/configuracion/impresora/toggle/";
  const URL_LISTAR       = "/configuracion/impresora/listar/";
  const URL_GUARDAR_IMP  = "/configuracion/impresora/guardar/";
  const URL_TEST         = "/configuracion/impresora/test/";
  const feedbackImp      = document.getElementById('ticket-feedback');
  const bloqueImpresora  = document.getElementById('bloque-impresora');
  const selectImpresora  = document.getElementById('select-impresora');

  function mostrarFeedbackImp(msg, ok) {
    feedbackImp.textContent = msg;
    feedbackImp.style.color = ok ? '#2d6a4f' : '#dc3545';
    if (ok) setTimeout(() => { feedbackImp.textContent = ''; }, 3000);
  }

  // Toggle activar/desactivar
  document.getElementById('toggle-impresora').addEventListener('change', function () {
    const activado = this.checked;
    bloqueImpresora.style.display = activado ? '' : 'none';

    fetch(URL_TOGGLE, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRFToken': CSRF },
      body: JSON.stringify({ activado }),
    })
      .then(r => r.json())
      .then(data => {
        if (data.ok) {
          mostrarFeedbackImp(activado ? 'Impresión automática activada.' : 'Impresión automática desactivada.', true);
        } else {
          mostrarFeedbackImp(data.error || 'Error al guardar.', false);
          this.checked = !activado;
          bloqueImpresora.style.display = !activado ? '' : 'none';
        }
      })
      .catch(() => { mostrarFeedbackImp('Error de conexión.', false); this.checked = !activado; });
  });

  // Listar impresoras instaladas en Windows
  document.getElementById('btn-listar').addEventListener('click', function () {
    this.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
    this.disabled  = true;

    fetch(URL_LISTAR)
      .then(r => r.json())
      .then(data => {
        const actual = selectImpresora.value;
        selectImpresora.innerHTML = '<option value="">— Selecciona una impresora —</option>';
        data.impresoras.forEach(nombre => {
          const opt      = document.createElement('option');
          opt.value      = nombre;
          opt.textContent = nombre;
          if (nombre === actual || nombre === data.predeterminada) opt.selected = true;
          selectImpresora.appendChild(opt);
        });
        if (data.impresoras.length === 0) {
          mostrarFeedbackImp('No se encontraron impresoras instaladas.', false);
        }
      })
      .catch(() => mostrarFeedbackImp('Error al listar impresoras.', false))
      .finally(() => {
        this.innerHTML = '<i class="bi bi-arrow-repeat"></i>';
        this.disabled  = false;
      });
  });

  // Guardar nombre de impresora
  document.getElementById('btn-guardar-impresora').addEventListener('click', function () {
    const nombre = selectImpresora.value.trim();
    if (!nombre) { mostrarFeedbackImp('Selecciona una impresora.', false); return; }

    fetch(URL_GUARDAR_IMP, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRFToken': CSRF },
      body: JSON.stringify({ nombre }),
    })
      .then(r => r.json())
      .then(data => mostrarFeedbackImp(data.ok ? 'Impresora guardada.' : (data.error || 'Error.'), data.ok))
      .catch(() => mostrarFeedbackImp('Error de conexión.', false));
  });

  // Test de impresión
  document.getElementById('btn-test-impresora').addEventListener('click', function () {
    this.disabled  = true;
    this.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Imprimiendo...';

    fetch(URL_TEST, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRFToken': CSRF },
      body: JSON.stringify({}),
    })
      .then(r => r.json())
      .then(data => mostrarFeedbackImp(data.ok ? '✓ Prueba enviada a la impresora.' : (data.error || 'Error.'), data.ok))
      .catch(() => mostrarFeedbackImp('Error de conexión.', false))
      .finally(() => {
        this.disabled  = false;
        this.innerHTML = '<i class="bi bi-printer me-1"></i>Imprimir prueba';
      });
  });
</script>

</body>
</html>
