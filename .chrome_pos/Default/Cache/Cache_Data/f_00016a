        <div id="pago-feedback" class="text-danger" style="font-size:.85rem; min-height:1rem;"></div>
      </div>
      <div class="modal-footer border-0 px-4 pb-4 pt-0">
        <button type="button" class="btn btn-success w-100 fw-bold py-2" id="btn-confirmar-pago">
          <i class="bi bi-check-lg me-1"></i>Registrar abono
        </button>
      </div>
    </div>
  </div>
</div>


