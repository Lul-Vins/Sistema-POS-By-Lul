<div class="modal fade" id="modalPago" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" style="max-width:440px;">
    <div class="modal-content border-0 shadow">
      <div class="modal-header" style="background:#2d6a4f; color:#fff; border:none;">
        <h5 class="modal-title fw-bold"><i class="bi bi-cash me-2"></i>Registrar abono</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" style="filter:invert(1);"></button>
      </div>
      <div class="modal-body px-4 pt-3">
        <input type="hidden" id="pago-fiado-pk" value="">
        <input type="hidden" id="pago-saldo-usd" value="">

        <!-- Saldo expresado en Bs de HOY -->
        <div class="caja-saldo-hoy">
          <div class="lbl">Saldo pendiente — al cambio de hoy</div>
